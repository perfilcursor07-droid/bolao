<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <div class="container home-container">
    <a href="/" class="back-link">← Voltar aos jogos</a>

    <div class="card game-detail-card">
      <span class="card-badge <%= game.status === 'open' ? 'open' : game.status === 'closed' ? 'closed' : 'finished' %>">
        <%= game.status === 'open' ? 'Aberto' : game.status === 'closed' ? 'Aguardando resultado' : 'Finalizado' %>
      </span>

      <h1 class="game-title"><%= game.title %></h1>
      <time class="game-date"><%= gameDateBR(game.game_date, { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></time>

      <div class="match-row match-row-lg">
        <div class="match-team">
          <span class="match-team-name"><%= teamPt(game.home_team) %></span>
          <% if (game.home_score !== null) { %><span class="match-score"><%= game.home_score %></span><% } %>
        </div>
        <span class="match-x">×</span>
        <div class="match-team">
          <span class="match-team-name"><%= teamPt(game.away_team) %></span>
          <% if (game.away_score !== null) { %><span class="match-score"><%= game.away_score %></span><% } %>
        </div>
      </div>

      <div class="game-stats">
        <div class="game-stat highlight">
          <span class="game-stat-val"><%= formatCents(game.prize_pool_cents) %></span>
          <span class="game-stat-lbl">prêmio acumulado</span>
        </div>
        <div class="game-stat">
          <span class="game-stat-val"><%= formatCents(game.entry_fee_cents) %></span>
          <span class="game-stat-lbl">por aposta</span>
        </div>
      </div>

      <% if (success) { %>
        <div class="alert alert-success">🎉 Aposta confirmada! Pode fazer outra se quiser.</div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <% if (game.status === 'open' && isBettingOpen(game) && user) { %>
        <div class="game-detail-actions">
          <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
            <a href="/carrinho" class="btn btn-outline btn-block" style="margin-bottom:0.5rem;">
              🛒 Carrinho (<%= cartCount %> palpite<%= cartCount !== 1 ? 's' : '' %>)
            </a>
          <% } %>
          <a href="/games/<%= game.id %>/placar" class="btn btn-gold btn-block btn-xl">
            🎯 Escolher placar
          </a>
          <a href="/" class="btn btn-outline btn-block btn-sm" style="margin-top:0.5rem;">
            + Apostar em outros bolões
          </a>
          <p class="action-hint">Adicione palpites ao carrinho e pague tudo junto, ou pague agora neste jogo</p>

          <!-- Pagamentos pendentes -->
          <% if (userStatus.pendingPayments && userStatus.pendingPayments.length > 0) { %>
            <div style="margin-top:1rem; padding:0.75rem; background:rgba(255,193,7,0.1); border:1px solid rgba(255,193,7,0.3); border-radius:8px;">
              <p style="font-size:0.85rem; font-weight:600; margin-bottom:0.5rem;">⏳ Pagamentos pendentes</p>
              <% userStatus.pendingPayments.forEach(function(pp) { %>
                <% const preds = pp.prediction_data ? (typeof pp.prediction_data === 'string' ? JSON.parse(pp.prediction_data) : pp.prediction_data) : null; %>
                <% const pPlacares = preds && preds.placares ? preds.placares : []; %>
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.4rem;">
                  <span style="font-size:0.8rem;">
                    <%= pPlacares.map(p => p.home + '×' + p.away).join(', ') %> — <%= formatCents(pp.amount_cents) %>
                  </span>
                  <a href="/payment/<%= pp.id %>" class="btn btn-primary btn-sm">Pagar</a>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>

        <!-- Apostas confirmadas -->
        <% if (userStatus.bets && userStatus.bets.length > 0) { %>
          <h3 class="section-title" style="margin-top: 1.5rem;">✅ Suas apostas neste jogo</h3>
          <div class="my-bets-inline">
            <% userStatus.bets.forEach(function(bet) { %>
              <div class="bet-inline-item" style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                  <strong><%= bet.home_score_prediction %> × <%= bet.away_score_prediction %></strong>
                  <% if (bet.is_winner) { %>
                    <span class="winner-badge">🏆 <%= formatCents(bet.prize_amount_cents) %></span>
                  <% } else if (game.status === 'finished') { %>
                    <span class="status-tag lost" style="font-size:0.7rem;">Não ganhou</span>
                  <% } else { %>
                    <span class="status-tag waiting" style="font-size:0.7rem;">Aguardando</span>
                  <% } %>
                </div>
                <% if (isBettingOpen(game)) { %>
                  <a href="/games/<%= game.id %>/bets/<%= bet.id %>/edit" class="btn btn-sm btn-outline" style="font-size:0.7rem;">✏️ Editar</a>
                <% } %>
              </div>
            <% }); %>
          </div>
        <% } %>
      <% } else if (game.status === 'open' && !isBettingOpen(game)) { %>
        <div class="alert betting-closed-alert" style="margin-top:1rem;">
          <strong>Apostas encerradas</strong>
          <p style="margin:0.35rem 0 0; font-size:0.85rem;">
            <% if (hasGameStarted(game)) { %>
              O jogo já começou. Não é mais possível apostar nem editar palpites.
            <% } else { %>
              O bolão fecha <%= bettingCloseMinutes %> minutos antes do jogo. Não é mais possível apostar nem editar palpites.
            <% } %>
          </p>
        </div>
        <% if (user && userStatus.bets && userStatus.bets.length > 0) { %>
          <h3 class="section-title" style="margin-top: 1.25rem;">✅ Suas apostas neste jogo</h3>
          <div class="my-bets-inline">
            <% userStatus.bets.forEach(function(bet) { %>
              <div class="bet-inline-item" style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                  <strong><%= bet.home_score_prediction %> × <%= bet.away_score_prediction %></strong>
                  <span class="status-tag waiting" style="font-size:0.7rem;">Aguardando</span>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      <% } else if (game.status === 'open' && isBettingOpen(game) && !user) { %>
        <a href="/games/<%= game.id %>/participar" class="btn btn-gold btn-block btn-xl" style="margin-top: 1rem;">
          Participar — <%= formatCents(game.entry_fee_cents) %>
        </a>
      <% } %>

      <% if (game.status === 'finished' && typeof prizeBreakdown !== 'undefined') { %>
        <div class="prize-breakdown prize-breakdown-card" id="ganhadores">
          <p class="prize-breakdown-title">Distribuição do prêmio</p>
          <div class="prize-breakdown-row">
            <span>Total arrecadado</span>
            <strong><%= formatCents(prizeBreakdown.totalPool) %></strong>
          </div>
          <div class="prize-breakdown-row prize-breakdown-fee">
            <span>Taxa do sistema (<%= prizeBreakdown.feePercent %>%)</span>
            <strong>− <%= formatCents(prizeBreakdown.feeCents) %></strong>
          </div>
          <div class="prize-breakdown-row prize-breakdown-net">
            <span>Prêmio líquido (<%= prizeBreakdown.netPercent %>%)</span>
            <strong><%= formatCents(prizeBreakdown.netPool) %></strong>
          </div>
          <% if (winners.length > 0) { %>
            <div class="prize-breakdown-row prize-breakdown-each">
              <span>Por ganhador (÷ <%= winners.length %>)</span>
              <strong class="prize-each-value"><%= formatCents(prizeBreakdown.prizeEach) %></strong>
            </div>
          <% } %>
        </div>
      <% } %>

      <% if (winners.length > 0) { %>
        <h3 class="section-title" style="margin-top: 2rem;">🏆 Ganhadores</h3>
        <div class="winners-list">
          <% winners.forEach(function(w) { %>
            <div class="winner-row">
              <span><%= w.name %></span>
              <span><%= w.home_score_prediction %> × <%= w.away_score_prediction %></span>
              <span class="prize-amount"><%= formatCents(w.prize_amount_cents) %></span>
            </div>
          <% }); %>
        </div>
      <% } else if (game.status === 'finished') { %>
        <div class="alert" style="margin-top: 1.25rem; background: rgba(100,116,139,0.1); border: 1px solid var(--border); color: var(--text-secondary); text-align: center;">
          Nenhum ganhador neste jogo.
        </div>
      <% } %>
    </div>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
