<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-ganhadores page-green">
  <%- include('partials/header') %>

  <section class="hero-twin hero-twin--compact" aria-label="Ganhadores">
    <div class="hero-twin-inner">
      <p class="hero-twin-kicker">🏆 Resultados oficiais</p>
      <h1 class="hero-twin-title">Ganhadores</h1>
      <p class="hero-twin-sub">Quem acertou o placar e levou o prêmio em cada bolão</p>
    </div>
  </section>

  <div class="container home-container page-green-content">
    <p class="ganhadores-hint">Participou sem conta? <a href="/consultar">Consulte pelo WhatsApp</a> se você ganhou.</p>

    <% if (winnerSummaries.length === 0) { %>
      <div class="empty-state empty-state--green">
        <div class="empty-icon">🏆</div>
        <p>Nenhum ganhador ainda</p>
        <small>Os ganhadores aparecem aqui quando um bolão é finalizado com acertos.</small>
      </div>
    <% } else { %>
      <p class="ganhadores-count"><%= winnerSummaries.length %> bolão<%= winnerSummaries.length !== 1 ? 'ões' : '' %> com ganhador<%= winnerSummaries.length !== 1 ? 'es' : '' %></p>
      <%- include('partials/finished-boloes-list', { finishedSummaries: winnerSummaries }) %>
    <% } %>

    <div class="page-sticky-spacer" aria-hidden="true"></div>
  </div>

  <div class="page-sticky-foot">
    <a href="/" class="btn btn-gold page-sticky-btn">Ver jogos abertos</a>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
