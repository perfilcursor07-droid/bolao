<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-placar">
  <%- include('partials/header') %>

  <div class="container home-container placar-page">
    <% if (typeof novo !== 'undefined' && novo) { %>
      <div class="alert alert-success placar-welcome">
        Cadastro feito! Escolha seu(s) placar(es) abaixo. Ao adicionar, o palpite vai para o carrinho 🛒 no topo.
      </div>
    <% } %>

    <div id="client-error" class="alert alert-error" style="display:none;"></div>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (userStatus.bets && userStatus.bets.length > 0) { %>
      <div class="placar-existing-bets">
        <p class="placar-existing-title">✅ Suas apostas neste jogo</p>
        <% userStatus.bets.forEach(function(bet) { %>
          <div class="placar-existing-row">
            <span><strong><%= bet.home_score_prediction %> × <%= bet.away_score_prediction %></strong> <span class="status-tag waiting">confirmado</span></span>
          </div>
        <% }); %>
        <p class="placar-existing-hint">Palpites já pagos não podem ser alterados. Para apostar de novo, adicione outro palpite abaixo e pague.</p>
      </div>
    <% } %>

    <p class="placar-flow-hint">Ajuste o placar, toque em <strong>Adicionar</strong> e repita quantas vezes quiser.</p>
    <div class="placar-picker-card" id="placar-picker-card">
      <div class="placar-picker-teams">
        <div class="placar-picker-side">
          <span class="placar-picker-team-name"><%= teamPt(game.home_team) %></span>
          <div class="placar-picker-controls">
            <button type="button" class="pbtn" id="btn-home-minus" aria-label="Menos gol <%= teamPt(game.home_team) %>">−</button>
            <span class="placar-picker-num" id="cur-home">0</span>
            <button type="button" class="pbtn" id="btn-home-plus" aria-label="Mais gol <%= teamPt(game.home_team) %>">+</button>
          </div>
        </div>
        <div class="placar-picker-x">×</div>
        <div class="placar-picker-side">
          <span class="placar-picker-team-name"><%= teamPt(game.away_team) %></span>
          <div class="placar-picker-controls">
            <button type="button" class="pbtn" id="btn-away-minus" aria-label="Menos gol <%= teamPt(game.away_team) %>">−</button>
            <span class="placar-picker-num" id="cur-away">0</span>
            <button type="button" class="pbtn" id="btn-away-plus" aria-label="Mais gol <%= teamPt(game.away_team) %>">+</button>
          </div>
        </div>
      </div>
      <button type="button" class="btn btn-accent btn-block placar-picker-add" id="btn-add-placar">
        + Adicionar <span id="add-preview">0×0</span> à lista
      </button>
      <p class="placar-picker-reset-hint" id="picker-hint">Após adicionar, o placar volta para 0×0.</p>
    </div>

    <div class="placar-quick-section">
      <p class="placar-quick-label">⚡ Atalhos — toque para adicionar na hora</p>
      <div class="placar-quick-grid" id="quick-grid">
        <button type="button" class="pq-btn" data-h="1" data-a="0"><b>1</b>×<b>0</b></button>
        <button type="button" class="pq-btn" data-h="2" data-a="1"><b>2</b>×<b>1</b></button>
        <button type="button" class="pq-btn" data-h="2" data-a="0"><b>2</b>×<b>0</b></button>
        <button type="button" class="pq-btn" data-h="3" data-a="0"><b>3</b>×<b>0</b></button>
        <button type="button" class="pq-btn" data-h="0" data-a="0"><b>0</b>×<b>0</b></button>
        <button type="button" class="pq-btn" data-h="1" data-a="1"><b>1</b>×<b>1</b></button>
        <button type="button" class="pq-btn" data-h="0" data-a="1"><b>0</b>×<b>1</b></button>
        <button type="button" class="pq-btn" data-h="0" data-a="2"><b>0</b>×<b>2</b></button>
      </div>
    </div>

    <div class="placar-cart" id="placar-cart">
      <div class="placar-cart-header">
        <span>🎟️ Palpites no carrinho</span>
        <span class="placar-cart-count" id="cart-count">0</span>
      </div>
      <div class="placar-cart-empty" id="cart-empty">
        Nenhum palpite ainda — use os botões acima para montar sua lista
      </div>
      <ul class="placar-cart-list" id="placar-list"></ul>
      <p class="placar-cart-hint" id="placar-cart-hint" style="display:none;">
        Você também pode pagar agora pelo botão fixo no rodapé.
      </p>
    </div>

    <div class="share-mini" id="share-mini">
      <button type="button" class="share-mini-btn" id="btn-share">📤 Compartilhar este bolão</button>
      <div class="share-mini-panel" id="share-panel" style="display:none;">
        <div class="share-mini-row">
          <input type="text" class="share-link-input" id="share-link" readonly>
          <button type="button" class="btn btn-accent btn-sm" id="btn-copy">Copiar</button>
        </div>
        <div class="share-mini-actions">
          <a id="btn-wa" href="#" target="_blank" class="share-btn share-btn-whatsapp">WhatsApp</a>
          <a id="btn-tg" href="#" target="_blank" class="share-btn share-btn-telegram">Telegram</a>
        </div>
      </div>
    </div>

    <div class="placar-bottom-spacer" id="bottom-spacer"></div>
  </div>

  <form method="POST" action="/games/<%= game.id %>/placar" id="placar-form" class="placar-sticky-footer" style="display:none;">
    <input type="hidden" name="placares_json" id="placares_json" value="[]">
    <div class="placar-sticky-info">
      <span id="sticky-count">0</span>
      <strong id="sticky-total">R$ 0,00</strong>
    </div>
    <div class="placar-sticky-actions placar-sticky-actions--solo">
      <button type="submit" class="btn btn-gold btn-pay" id="btn-pay">
        Pagar agora
      </button>
    </div>
  </form>

  <script>
    const FEE = <%= game.entry_fee_cents %>;
    const GAME_ID = <%= game.id %>;
    const HT = <%- JSON.stringify(teamPt(game.home_team)) %>;
    const AT = <%- JSON.stringify(teamPt(game.away_team)) %>;

    let placares = <%- JSON.stringify(cartPlacares || []) %>;
    let cH = 0, cA = 0;
    let cartBusy = false;

    const $ = id => document.getElementById(id);
    const elH = $('cur-home'), elA = $('cur-away');
    const elPrev = $('add-preview');
    const elList = $('placar-list'), elEmpty = $('cart-empty');
    const elCount = $('cart-count');
    const elJson = $('placares_json');
    const elPay = $('btn-pay');
    const elSCount = $('sticky-count'), elSTotal = $('sticky-total');
    const elForm = $('placar-form'), elSpacer = $('bottom-spacer');
    const elErr = $('client-error');
    const elPickerCard = $('placar-picker-card');
    const elPickerHint = $('picker-hint');
    const elPlacarCart = $('placar-cart');
    const elCartHint = $('placar-cart-hint');
    const elBtnAdd = $('btn-add-placar');

    const fmt = c => (c/100).toLocaleString('pt-BR',{style:'currency',currency:'BRL'});

    function err(m) { elErr.textContent=m; elErr.style.display='block'; window.scrollTo({top:0,behavior:'smooth'}); }
    function noErr() { elErr.style.display='none'; }

    function updateCartBadges(data) {
      const total = (data.badgeTotal != null)
        ? data.badgeTotal
        : (data.cartCount || 0) + (data.pendingPaymentsCount || 0);

      const cartBtn = document.querySelector('.nav-cart-btn');
      if (cartBtn) {
        let badge = cartBtn.querySelector('.nav-cart-badge');
        if (total > 0) {
          if (!badge) {
            badge = document.createElement('span');
            badge.className = 'nav-cart-badge';
            cartBtn.appendChild(badge);
          }
          badge.textContent = total;
          cartBtn.setAttribute('aria-label', 'Carrinho, ' + total + ' pendente' + (total !== 1 ? 's' : ''));
        } else if (badge) {
          badge.remove();
          cartBtn.setAttribute('aria-label', 'Carrinho');
        }
      }

      const mobileLink = document.querySelector('.nav-mobile-link[href="/carrinho"]');
      if (mobileLink) {
        let mbadge = mobileLink.querySelector('.nav-mobile-badge');
        if (total > 0) {
          if (!mbadge) {
            mbadge = document.createElement('span');
            mbadge.className = 'nav-mobile-badge';
            mobileLink.appendChild(mbadge);
          }
          mbadge.textContent = total;
        } else if (mbadge) {
          mbadge.remove();
        }
      }
    }

    async function pushToCart(h, a) {
      const res = await fetch('/games/' + GAME_ID + '/cart/add', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ placares: [{ home: h, away: a }] }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) throw new Error(data.error || 'cart');
      return data;
    }

    function flashPicker(msg) {
      if (!elPickerHint) return;
      const prev = elPickerHint.textContent;
      elPickerHint.textContent = msg;
      elPickerHint.classList.add('is-flash');
      if (elPickerCard) elPickerCard.classList.add('is-added');
      setTimeout(() => {
        elPickerHint.textContent = prev;
        elPickerHint.classList.remove('is-flash');
        if (elPickerCard) elPickerCard.classList.remove('is-added');
      }, 1400);
    }

    function resetPicker() {
      cH = 0;
      cA = 0;
      upd();
    }

    function upd() {
      elH.textContent = cH; elA.textContent = cA;
      elPrev.textContent = cH+'×'+cA;
    }

    function dup(h,a) { return placares.some(p=>p.home===h&&p.away===a); }

    function setBusy(busy) {
      cartBusy = busy;
      if (elBtnAdd) elBtnAdd.disabled = busy;
      document.querySelectorAll('.pq-btn').forEach(b => { b.disabled = busy; });
    }

    async function add(h, a, opts) {
      const fromQuick = opts && opts.quick;
      if (dup(h,a)) {
        flashPicker('⚠️ ' + h + '×' + a + ' já está na lista');
        if (!fromQuick) resetPicker();
        return false;
      }

      setBusy(true);
      try {
        const data = await pushToCart(h, a);
        placares.push({ home: h, away: a });
        noErr();
        render();
        updateCartBadges(data);
        resetPicker();
        flashPicker('✓ ' + h + '×' + a + ' no carrinho!');
        const lastItem = elList.lastElementChild;
        if (lastItem) {
          lastItem.classList.add('pc-item--new');
          setTimeout(() => lastItem.classList.remove('pc-item--new'), 1200);
        }
        if (elPlacarCart && placares.length === 1) {
          elPlacarCart.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        return true;
      } catch (_) {
        err('Não foi possível adicionar ao carrinho. Tente de novo.');
        return false;
      } finally {
        setBusy(false);
      }
    }

    function render() {
      elList.innerHTML = '';
      placares.forEach((p) => {
        const li = document.createElement('li');
        li.className = 'pc-item';
        li.innerHTML =
          '<span class="pc-score"><b>' + HT + '</b> ' + p.home + ' × ' + p.away + ' <b>' + AT + '</b></span>' +
          '<span class="pc-fee">' + fmt(FEE) + '</span>' +
          '<form method="POST" action="/games/' + GAME_ID + '/placar/remove" class="pc-rm-form">' +
            '<input type="hidden" name="home" value="' + p.home + '">' +
            '<input type="hidden" name="away" value="' + p.away + '">' +
            '<button type="submit" class="pc-rm" aria-label="Remover palpite">✕</button>' +
          '</form>';
        elList.appendChild(li);
      });

      const n = placares.length;
      elEmpty.style.display = n ? 'none' : 'block';
      elCount.textContent = n;
      elJson.value = JSON.stringify(placares);
      if (elCartHint) elCartHint.style.display = n ? 'block' : 'none';
      document.body.classList.toggle('has-placar-pay', n > 0);

      if (n) {
        elForm.style.display = 'flex';
        elSpacer.style.display = 'block';
        elSCount.textContent = n + ' palpite' + (n > 1 ? 's' : '');
        elSTotal.textContent = fmt(FEE * n);
        elPay.disabled = cartBusy;
        elPay.textContent = 'Pagar ' + fmt(FEE * n);
      } else {
        elForm.style.display = 'none';
        elSpacer.style.display = 'none';
        elPay.disabled = true;
      }

      document.querySelectorAll('.pq-btn').forEach(b => {
        const bh=+b.dataset.h, ba=+b.dataset.a;
        b.classList.toggle('added', dup(bh,ba));
        b.disabled = cartBusy;
      });
    }

    $('btn-home-plus').onclick = ()=>{ if(cH<20){cH++;upd();} };
    $('btn-home-minus').onclick = ()=>{ if(cH>0){cH--;upd();} };
    $('btn-away-plus').onclick = ()=>{ if(cA<20){cA++;upd();} };
    $('btn-away-minus').onclick = ()=>{ if(cA>0){cA--;upd();} };
    elBtnAdd.onclick = () => add(cH, cA);

    document.querySelectorAll('.pq-btn').forEach(b => {
      b.onclick = () => add(+b.dataset.h, +b.dataset.a, { quick: true });
    });

    $('placar-form').addEventListener('submit', function (e) {
      if (elPay.classList.contains('is-loading')) {
        e.preventDefault();
        return;
      }
      noErr();
      elJson.value = JSON.stringify(placares);
      elPay.classList.add('is-loading');
      elPay.setAttribute('aria-busy', 'true');
      elPay.textContent = '⏳ Gerando PIX...';
    });

    upd();
    render();

    const shareUrl = window.location.origin + '/games/<%= game.id %>/participar';
    const shareTxt = 'Bolão: ' + HT + ' × ' + AT + ' — ' + fmt(FEE) + '/placar!';
    $('share-link').value = shareUrl;
    $('btn-share').onclick = () => {
      const panel = $('share-panel');
      panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
    };
    $('btn-copy').onclick = function() {
      navigator.clipboard.writeText(shareUrl).then(() => { this.textContent='✓'; setTimeout(()=>{this.textContent='Copiar';},1500); });
    };
    $('btn-wa').href = 'https://wa.me/?text=' + encodeURIComponent(shareTxt+'\n'+shareUrl);
    $('btn-tg').href = 'https://t.me/share/url?url='+encodeURIComponent(shareUrl)+'&text='+encodeURIComponent(shareTxt);
  </script>
</body>
</html>
