<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <div class="container home-container">
    <a href="/" class="back-link">← Voltar aos jogos</a>

    <div class="page-header-compact">
      <h1>Bolões encerrados</h1>
      <% if (finishedSummaries.length > 0) { %>
        <span class="home-count"><%= finishedSummaries.length %></span>
      <% } %>
    </div>

    <% if (finishedSummaries.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">🏁</div>
        <p>Nenhum bolão encerrado com apostas ainda.</p>
        <a href="/" class="btn btn-primary btn-block" style="margin-top: 1rem; max-width: 280px; margin-left: auto; margin-right: auto;">Ver jogos abertos</a>
      </div>
    <% } else { %>
      <%- include('partials/finished-boloes-list', { finishedSummaries, showAllBets: true }) %>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
