<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-admin">
  <%- include('layout') %>

    <div class="copa-sync-bar">
      <div class="copa-sync-info">
        <% if (typeof apiStatus !== 'undefined' && apiStatus) { %>
          <span class="copa-api-badge copa-api-badge--<%= apiStatus.primary %>">API: <%= apiStatus.label %></span>
        <% } %>
        <% if (typeof cachedAt !== 'undefined' && cachedAt) { %>
          <span>Atualizado <%= gameDateBR(new Date(cachedAt), { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
          <% if (typeof fromCache !== 'undefined' && fromCache) { %>
            <span class="copa-sync-cache">· cache</span>
          <% } %>
        <% } else { %>
          <span>Dados da football-data.org</span>
        <% } %>
        <% if (typeof hasLive !== 'undefined' && hasLive) { %>
          <span class="copa-sync-live">· placar ao vivo ~20s (<%= typeof apiStatus !== 'undefined' && apiStatus?.wc2026Source === 'football-data' ? 'football-data.org' : 'API-Football' %>)</span>
        <% } %>
        <% if (typeof apiStatus !== 'undefined' && apiStatus?.note) { %>
          <span class="copa-sync-hint-inline" style="display:block;font-size:0.75rem;color:var(--text-muted);margin-top:0.25rem;"><%= apiStatus.note %></span>
        <% } %>
      </div>
      <a href="/admin/copa?refresh=1" class="btn btn-sm btn-outline">↻ Atualizar agora</a>
    </div>
    <p class="copa-sync-hint">
      Marque jogos para criar bolões.
      Jogos com <strong>✓ Bolão criado</strong> ficam desativados para não duplicar.
      <strong>Jogos ao vivo</strong> também podem ser adicionados — entram como encerrados para apostas, com placar sincronizado.
    </p>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="alert alert-info"><%= flash %></div>
    <% } %>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
      <div class="card" style="padding:1.5rem; text-align:center;">
        <p style="margin-bottom:1rem;">Para placar ao vivo da <strong>Copa 2026</strong>, configure a chave gratuita da <strong>football-data.org</strong> (10 req/min):</p>
        <ol style="text-align:left; color:var(--text-secondary); font-size:0.9rem; margin-bottom:1rem;">
          <li>Acesse <a href="https://www.football-data.org/client/register" target="_blank">football-data.org</a> e crie conta grátis</li>
          <li>Copie o token no painel</li>
          <li>No <code>.env</code> do servidor: <code>FOOTBALL_API_KEY=seu-token</code></li>
          <li>Reinicie o app (<code>pm2 restart bolaopix</code>)</li>
        </ol>
        <p style="font-size:0.8rem; color:var(--text-muted); margin-bottom:1rem;">
          Opcional: <code>APISPORTS_KEY</code> em <a href="https://www.api-football.com/" target="_blank">api-football.com</a> — será usada automaticamente quando publicarem a Copa 2026.
        </p>
      </div>
    <% } else if (matches && matches.length > 0) { %>

      <!-- Toolbar de seleção -->
      <form method="POST" action="/admin/copa/create-bulk" id="bulk-form">
        <div class="copa-toolbar">
          <div class="copa-toolbar-left">
            <label class="copa-select-all">
              <input type="checkbox" id="select-all"> Selecionar tudo
            </label>
            <span class="copa-selected-count" id="selected-count">0 selecionados</span>
          </div>
          <div class="copa-toolbar-right">
            <label class="copa-fee-label">
              Valor R$
              <input type="number" name="entry_fee" value="<%= typeof defaultEntryFee !== 'undefined' ? defaultEntryFee : '10.00' %>" min="1" step="0.01" class="copa-fee-input-main" id="global-fee">
            </label>
            <button type="submit" class="btn btn-primary" id="btn-create-bulk" disabled>
              Criar bolões selecionados
            </button>
          </div>
        </div>

        <%
          const stages = {};
          matches.forEach(m => {
            const key = m.stage || 'OTHER';
            if (!stages[key]) stages[key] = [];
            stages[key].push(m);
          });
          const stageNames = {
            'GROUP_STAGE': 'Fase de Grupos',
            'ROUND_OF_16': 'Oitavas de Final',
            'QUARTER_FINALS': 'Quartas de Final',
            'SEMI_FINALS': 'Semifinais',
            'THIRD_PLACE': 'Disputa 3º lugar',
            'FINAL': 'Final',
            'OTHER': 'Outros',
            'KNOCKOUT': 'Eliminatórias'
          };
        %>

        <% var existingIds = typeof existingApiMatchIds !== 'undefined' ? existingApiMatchIds.map(String) : []; %>
        <% var existingFps = typeof existingFingerprints !== 'undefined' ? existingFingerprints : []; %>
        <% Object.keys(stages).forEach(function(stage) { %>
          <div class="copa-stage-header">
            <span><%= stageNames[stage] || stage %></span>
            <button type="button" class="copa-stage-select-btn" data-stage="<%= stage %>">Selecionar fase</button>
          </div>
          <div class="copa-stage-list">
            <% stages[stage].forEach(function(m) { %>
              <% var matchNotFinished = m.status !== 'FINISHED' && m.status !== 'AWARDED' && m.status !== 'CANCELLED' && m.status !== 'POSTPONED'; %>
              <% var hasTeams = m.homeTeam && m.awayTeam && m.homeTeam !== 'A definir' && m.awayTeam !== 'A definir'; %>
              <% var matchFp = gameFingerprint(m.homeTeam, m.awayTeam, toMySQLDateTime(m.date)); %>
              <% var alreadyCreated = existingIds.indexOf(String(m.id)) !== -1 || existingFps.indexOf(matchFp) !== -1; %>
              <% var canCreateBolao = matchNotFinished && hasTeams && !alreadyCreated; %>
              <label class="copa-match-item copa-match-selectable<%= alreadyCreated ? ' copa-match-already' : '' %><%= !canCreateBolao && !alreadyCreated ? ' copa-match-unavailable' : '' %><%= (m.status === 'IN_PLAY' || m.status === 'PAUSED') && canCreateBolao ? ' copa-match-live-create' : '' %>" data-stage="<%= stage %>">
                <% if (canCreateBolao) { %>
                  <input type="checkbox" class="copa-check" name="matches[]"
                    value="<%- JSON.stringify({ home_team: m.homeTeam, away_team: m.awayTeam, game_date: toMySQLDateTime(m.date), api_match_id: String(m.id), api_status: m.status, home_score: m.homeScore, away_score: m.awayScore }).replace(/"/g, '&quot;') %>">
                <% } else { %>
                  <input type="checkbox" disabled class="copa-check copa-check--disabled"
                    title="<%= alreadyCreated ? 'Bolão já criado para este jogo' : !matchNotFinished ? 'Jogo finalizado ou cancelado' : !hasTeams ? 'Times ainda não definidos' : 'Indisponível' %>">
                <% } %>
                <div class="copa-match-info">
                  <div class="copa-match-teams">
                    <strong><%= teamPt(m.homeTeam) %></strong>
                    <span class="copa-match-vs">
                      <% if (m.homeScore !== null) { %>
                        <%= m.homeScore %> × <%= m.awayScore %>
                      <% } else { %>
                        ×
                      <% } %>
                    </span>
                    <strong><%= teamPt(m.awayTeam) %></strong>
                  </div>
                  <div class="copa-match-meta">
                    <time><%= gameDateBR(m.date) %></time>
                    <span class="copa-match-status <%= m.status === 'FINISHED' || m.status === 'AWARDED' ? 'finished' : m.status === 'IN_PLAY' || m.status === 'PAUSED' || m.status === 'LIVE' ? 'live' : '' %>">
                      <%= m.status === 'SCHEDULED' || m.status === 'TIMED' ? 'Agendado' : m.status === 'IN_PLAY' || m.status === 'PAUSED' || m.status === 'LIVE' ? '🔴 AO VIVO' : m.status === 'FINISHED' || m.status === 'AWARDED' ? 'Finalizado' : m.status %>
                      <% if ((m.status === 'IN_PLAY' || m.status === 'PAUSED') && canCreateBolao) { %>
                        <span class="copa-match-badge-live-create" title="Pode criar bolão — apostas encerradas"> · pode adicionar</span>
                      <% } %>
                      <% if (alreadyCreated) { %>
                        <span class="copa-match-badge-created">✓ Bolão criado</span>
                      <% } %>
                      <% if (m.bracketCertainty === 'confirmed') { %>
                        <span class="copa-certainty-badge copa-certainty-badge--confirmed" title="Times confirmados"> · ✓</span>
                      <% } %>
                    </span>
                  </div>
                </div>
              </label>
            <% }); %>
          </div>
        <% }); %>
      </form>

    <% } else { %>
      <div class="empty-state">
        <div class="empty-icon">🏆</div>
        <p>Nenhuma partida encontrada</p>
        <small>A Copa 2026 pode ainda não ter jogos agendados na API ou houve erro de conexão. Tente novamente.</small>
      </div>
    <% } %>

  <%- include('layout-close') %>

  <script>
    const checks = document.querySelectorAll('.copa-check:not(:disabled)');
    const selectAll = document.getElementById('select-all');
    const countEl = document.getElementById('selected-count');
    const btnCreate = document.getElementById('btn-create-bulk');

    function updateCount() {
      const n = document.querySelectorAll('.copa-check:not(:disabled):checked').length;
      const total = document.querySelectorAll('.copa-check:not(:disabled)').length;
      countEl.textContent = n + ' selecionado' + (n !== 1 ? 's' : '');
      btnCreate.disabled = n === 0;
      btnCreate.textContent = n === 0 ? 'Criar bolões selecionados' : 'Criar ' + n + ' bolão' + (n > 1 ? 'es' : '');
      if (selectAll) {
        selectAll.checked = total > 0 && n === total;
        selectAll.indeterminate = n > 0 && n < total;
      }
    }

    if (selectAll) {
      selectAll.onchange = () => {
        checks.forEach(c => { c.checked = selectAll.checked; });
        updateCount();
      };
    }

    checks.forEach(c => { c.onchange = updateCount; });

    document.querySelectorAll('.copa-stage-select-btn').forEach(btn => {
      btn.onclick = () => {
        const stage = btn.dataset.stage;
        const items = document.querySelectorAll(`.copa-match-selectable[data-stage="${stage}"] .copa-check:not(:disabled)`);
        const allChecked = items.length > 0 && Array.from(items).every(c => c.checked);
        items.forEach(c => { c.checked = !allChecked; });
        updateCount();
      };
    });

    updateCount();

    <% if (typeof hasLive !== 'undefined' && hasLive) { %>
    setTimeout(() => { window.location.reload(); }, 180000);
    <% } %>
  </script>
</body>
</html>
