<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-admin">
  <%- include('layout') %>

    <div class="admin-page-intro">
      <p>Defina valores padrão e preferências do bolão.</p>
    </div>

    <div class="admin-settings-card">
      <div class="admin-settings-head">
        <div>
          <h2>Valor do bolão</h2>
          <p>Valor padrão por placar em novos jogos, na Copa e nos bolões abertos.</p>
        </div>
        <div class="admin-settings-current">
          <span>Atual</span>
          <strong><%= formatCents(Math.round(parseFloat(defaultEntryFee) * 100)) %></strong>
        </div>
      </div>

      <% if (settingsSaved) { %>
        <div class="alert alert-success">
          Valor padrão atualizado com sucesso.
          <% if (typeof gamesUpdated === 'number' && gamesUpdated > 0) { %>
            <%= gamesUpdated %> jogo<%= gamesUpdated !== 1 ? 's' : '' %> aberto<%= gamesUpdated !== 1 ? 's' : '' %> atualizado<%= gamesUpdated !== 1 ? 's' : '' %>.
          <% } %>
        </div>
      <% } %>
      <% if (settingsError) { %>
        <div class="alert alert-error"><%= settingsError %></div>
      <% } %>

      <form method="POST" action="/admin/settings/entry-fee" class="admin-settings-form">
        <label for="default_entry_fee">Valor padrão por placar (R$)</label>
        <div class="admin-settings-row">
          <input
            type="number"
            id="default_entry_fee"
            name="entry_fee"
            class="form-control"
            step="0.01"
            min="1"
            required
            value="<%= typeof defaultEntryFee !== 'undefined' ? defaultEntryFee : '10.00' %>"
          >
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
        <label class="admin-settings-check">
          <input type="checkbox" name="apply_open" value="1" checked>
          <span>Atualizar também todos os <strong>jogos abertos</strong> com este valor</span>
        </label>
        <small class="admin-settings-hint">
          Jogos encerrados ou finalizados não são alterados. Pagamentos pendentes já gerados mantêm o valor antigo.
        </small>
      </form>
    </div>

  <%- include('layout-close') %>
</body>
</html>
