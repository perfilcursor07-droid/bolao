<div class="admin-shell" id="admin-shell">
  <div class="admin-sidebar-backdrop" id="admin-sidebar-backdrop" aria-hidden="true"></div>

  <aside class="admin-sidebar" id="admin-sidebar" aria-label="Menu administrativo">
    <div class="admin-sidebar-head">
      <a href="/admin" class="admin-sidebar-brand">
        <%- include('../partials/logo') %>
        <span class="admin-sidebar-brand-text">
          <strong>Bolão Online</strong>
          <small>Painel administrativo</small>
        </span>
      </a>
      <button type="button" class="admin-sidebar-close" id="admin-sidebar-close" aria-label="Fechar menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <nav class="admin-sidebar-nav">
      <div class="sidebar-group">
        <span class="sidebar-section">Principal</span>
        <a href="/admin" class="sidebar-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>" title="Dashboard">
          <span class="sidebar-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg></span>
          <span class="sidebar-label">Dashboard</span>
        </a>
        <a href="/admin/partidas" class="sidebar-item <%= typeof activePage !== 'undefined' && activePage === 'partidas' ? 'active' : '' %>" title="Partidas">
          <span class="sidebar-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18M3 12h18"/></svg></span>
          <span class="sidebar-label">Partidas</span>
        </a>
        <a href="/admin/apostas" class="sidebar-item <%= typeof activePage !== 'undefined' && activePage === 'apostas' ? 'active' : '' %>" title="Apostas">
          <span class="sidebar-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg></span>
          <span class="sidebar-label">Apostas</span>
        </a>
        <a href="/admin/copa" class="sidebar-item <%= typeof activePage !== 'undefined' && activePage === 'copa' ? 'active' : '' %>" title="Copa 2026">
          <span class="sidebar-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 4 5.5 4 9s-1.5 6.5-4 9M12 3c-2.5 2.5-4 5.5-4 9s1.5 6.5 4 9"/></svg></span>
          <span class="sidebar-label">Copa 2026</span>
        </a>
      </div>

      <div class="sidebar-group">
        <span class="sidebar-section">Financeiro</span>
        <a href="/admin/ganhadores" class="sidebar-item <%= typeof activePage !== 'undefined' && activePage === 'ganhadores' ? 'active' : '' %>" title="Ganhadores">
          <span class="sidebar-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21h8M12 17v4M7 4h10l1 5H6l1-5zM9 9v3a3 3 0 0 0 6 0V9"/></svg></span>
          <span class="sidebar-label">Ganhadores</span>
        </a>
        <a href="/admin/pagamentos" class="sidebar-item <%= typeof activePage !== 'undefined' && activePage === 'pagamentos' ? 'active' : '' %>" title="Pagamentos">
          <span class="sidebar-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span>
          <span class="sidebar-label">Pagamentos</span>
        </a>
      </div>

      <div class="sidebar-group">
        <span class="sidebar-section">Sistema</span>
        <a href="/admin/configuracoes" class="sidebar-item <%= typeof activePage !== 'undefined' && activePage === 'configuracoes' ? 'active' : '' %>" title="Configurações">
          <span class="sidebar-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg></span>
          <span class="sidebar-label">Configurações</span>
        </a>
      </div>
    </nav>

    <div class="admin-sidebar-foot">
      <a href="/" class="sidebar-item sidebar-item-site" title="Ver site">
        <span class="sidebar-icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6"/><path d="M10 14 21 3"/></svg></span>
        <span class="sidebar-label">Ver site público</span>
      </a>
      <% if (typeof user !== 'undefined' && user) { %>
        <div class="admin-sidebar-user">
          <span class="nav-avatar"><%= user.name.charAt(0).toUpperCase() %></span>
          <div class="admin-sidebar-user-info">
            <span class="admin-sidebar-user-name"><%= user.name.split(' ')[0] %></span>
            <span class="admin-sidebar-user-role">Administrador</span>
          </div>
        </div>
      <% } %>
    </div>
  </aside>

  <div class="admin-content">
    <header class="admin-topbar">
      <button type="button" class="admin-topbar-toggle" id="admin-sidebar-toggle" aria-label="Alternar menu">
        <svg class="admin-icon-menu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        <svg class="admin-icon-collapse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div class="admin-topbar-title">
        <% if (typeof title !== 'undefined') { %>
          <h1><%= title %></h1>
        <% } %>
      </div>
      <a href="/" class="admin-topbar-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6"/><path d="M10 14 21 3"/></svg>
        <span>Ver site</span>
      </a>
    </header>

    <main class="admin-main">
