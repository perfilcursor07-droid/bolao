<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-admin">
  <%- include('layout') %>

    <h1 style="font-size:1.25rem; margin-bottom:1rem;">🏆 Ganhadores</h1>

    <% if (winners.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">🏆</div>
        <p>Nenhum ganhador ainda</p>
        <small>Os ganhadores aparecem automaticamente quando um jogo é finalizado</small>
      </div>
    <% } else { %>
      <div class="table-container">
        <table>
          <thead>
            <tr><th>Jogador</th><th>PIX</th><th>Jogo</th><th>Resultado</th><th>Palpite</th><th>Prêmio (85%)</th><th>Pago?</th></tr>
          </thead>
          <tbody>
            <% winners.forEach(w => { %>
              <tr>
                <td><strong><%= w.user_name %></strong></td>
                <td style="font-size:0.75rem; color:var(--text-muted);"><%= w.user_pix || '—' %></td>
                <td><%= w.home_team %> × <%= w.away_team %></td>
                <td><%= w.home_score %>×<%= w.away_score %></td>
                <td><strong style="color:var(--accent);"><%= w.home_score_prediction %>×<%= w.away_score_prediction %></strong></td>
                <td class="prize-amount"><%= formatCents(w.prize_amount_cents) %></td>
                <td>
                  <% if (w.prize_paid_at) { %>
                    <span class="card-badge finished">✓ Pago</span>
                  <% } else { %>
                    <span class="card-badge closed">Pendente</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>

  </main>
</div>
</body>
</html>
