<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-admin">
  <%- include('layout') %>

    <p class="admin-page-intro">
      Todos os usuários cadastrados no sistema — participantes, convidados e administradores.
      Telefones no formato <strong>+55 (DDD) 9XXXX-XXXX</strong> aparecem como <strong>WhatsApp OK</strong> e recebem mensagens automáticas.
    </p>

    <% if (typeof saved !== 'undefined' && saved) { %>
      <div class="alert alert-success">Usuário atualizado com sucesso.</div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <% if (users.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">👤</div>
        <p>Nenhum usuário cadastrado</p>
      </div>
    <% } else { %>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Nome</th>
              <th>E-mail</th>
              <th>Telefone</th>
              <th>PIX / CPF</th>
              <th>Tipo</th>
              <th>Apostas</th>
              <th>Pagamentos</th>
              <th>Cadastro</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) {
              const roleLabel = u.role === 'admin' ? 'Administrador' : u.role === 'guest' ? 'Convidado' : 'Usuário';
              const roleClass = u.role === 'admin' ? 'finished' : u.role === 'guest' ? 'closed' : 'open';
            %>
              <tr>
                <td><strong><%= u.name %></strong></td>
                <td style="font-size:0.8rem; color:var(--text-muted);"><%= u.email || '—' %></td>
                <td style="font-size:0.8rem;">
                  <% if (u.phone) { %>
                    <span><%= u.phone_display %></span>
                    <% if (u.phone_whatsapp_ok) { %>
                      <span class="card-badge open" style="display:inline-block;margin-top:0.2rem;font-size:0.62rem;">WhatsApp OK</span>
                    <% } else { %>
                      <span class="card-badge finished" style="display:inline-block;margin-top:0.2rem;font-size:0.62rem;" title="Corrija o telefone (DDD+número completo)">WhatsApp?</span>
                    <% } %>
                    <% if (u.phone_normalized && u.phone !== u.phone_normalized) { %>
                      <small class="admin-cell-muted" style="display:block;">Salvo: <%= u.phone %></small>
                    <% } %>
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td style="font-size:0.75rem; color:var(--text-muted);"><%= u.cpf || '—' %></td>
                <td><span class="card-badge <%= roleClass %>"><%= roleLabel %></span></td>
                <td><%= u.total_bets %></td>
                <td><%= u.paid_payments %></td>
                <td style="font-size:0.8rem; color:var(--text-muted); white-space:nowrap;"><%= new Date(u.created_at).toLocaleString('pt-BR') %></td>
                <td>
                  <button
                    type="button"
                    class="btn btn-outline btn-sm btn-edit-user"
                    data-user-id="<%= u.id %>"
                    data-user-name="<%= u.name %>"
                    data-user-phone="<%= u.phone || '' %>"
                    data-user-cpf="<%= u.cpf || '' %>"
                    data-user-role="<%= u.role %>"
                  >Editar</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>

    <div class="admin-bet-modal" id="admin-user-modal" hidden>
      <div class="admin-bet-modal-backdrop" id="admin-user-modal-backdrop"></div>
      <div class="admin-bet-modal-dialog" role="dialog" aria-labelledby="admin-user-modal-title" aria-modal="true">
        <header class="admin-bet-modal-header">
          <div>
            <h2 class="admin-bet-modal-title" id="admin-user-modal-title">Editar usuário</h2>
            <p class="admin-bet-modal-sub" id="admin-user-modal-role"></p>
          </div>
          <button type="button" class="admin-bet-modal-close" id="admin-user-modal-close" aria-label="Fechar">×</button>
        </header>
        <form method="POST" action="" id="admin-user-edit-form" class="admin-bet-modal-body">
          <div class="form-group">
            <label for="admin-user-name">Nome</label>
            <input type="text" id="admin-user-name" name="name" class="form-control" required minlength="2">
          </div>
          <div class="form-group">
            <label for="admin-user-phone-country">Telefone (WhatsApp)</label>
            <div class="participar-phone-row">
              <div class="participar-country-picker" id="admin-user-phone-picker">
                <input type="hidden" id="admin-user-phone-country" name="phone_country" value="55">
                <button type="button" class="participar-country-trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="País">
                  <span class="participar-country-flag"></span>
                  <span class="participar-country-label">+55 Brasil</span>
                  <span class="participar-country-chevron" aria-hidden="true"></span>
                </button>
                <ul class="participar-country-menu" role="listbox" hidden></ul>
              </div>
              <input type="tel" id="admin-user-phone" name="phone" class="form-control participar-input" placeholder="(11) 98114-1234" required>
            </div>
            <small class="admin-cell-muted">Brasil: (DDD) + 9 + celular — ex. (11) 98114-1234</small>
          </div>
          <div class="form-group">
            <label for="admin-user-cpf">Chave PIX / CPF</label>
            <input type="text" id="admin-user-cpf" name="cpf" class="form-control" required minlength="5">
          </div>
          <div class="admin-bet-modal-actions">
            <button type="button" class="btn btn-outline" id="admin-user-cancel">Cancelar</button>
            <button type="submit" class="btn btn-gold">Salvar</button>
          </div>
        </form>
      </div>
    </div>

    <script src="/js/phone-input.js"></script>
    <script>
      (function () {
        const modal = document.getElementById('admin-user-modal');
        const form = document.getElementById('admin-user-edit-form');
        const backdrop = document.getElementById('admin-user-modal-backdrop');
        const closeBtn = document.getElementById('admin-user-modal-close');
        const cancelBtn = document.getElementById('admin-user-cancel');
        const roleEl = document.getElementById('admin-user-modal-role');
        const nameInput = document.getElementById('admin-user-name');
        const cpfInput = document.getElementById('admin-user-cpf');

        let phoneWidget = null;

        const roleLabels = { admin: 'Administrador', guest: 'Convidado', user: 'Usuário' };

        function closeModal() {
          modal.hidden = true;
          document.body.classList.remove('admin-modal-open');
        }

        function openModal(btn) {
          form.action = '/admin/usuarios/' + btn.dataset.userId + '/editar';
          nameInput.value = btn.dataset.userName || '';
          cpfInput.value = btn.dataset.userCpf || '';
          roleEl.textContent = roleLabels[btn.dataset.userRole] || btn.dataset.userRole;

          if (!phoneWidget) {
            phoneWidget = PhoneInput.init({
              countryPicker: '#admin-user-phone-picker',
              phoneInput: '#admin-user-phone',
              defaultCountry: '55',
            });
          }
          phoneWidget.setFromStored(btn.dataset.userPhone || '');

          modal.hidden = false;
          document.body.classList.add('admin-modal-open');
          nameInput.focus();
        }

        document.querySelectorAll('.btn-edit-user').forEach((btn) => {
          btn.addEventListener('click', () => openModal(btn));
        });

        backdrop.addEventListener('click', closeModal);
        closeBtn.addEventListener('click', closeModal);
        cancelBtn.addEventListener('click', closeModal);

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !modal.hidden) closeModal();
        });
      })();
    </script>

  <%- include('layout-close') %>
</body>
</html>
