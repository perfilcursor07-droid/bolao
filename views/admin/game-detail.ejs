<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="container">
    <a href="/admin" style="color: var(--text-muted); font-size: 0.85rem;">← Voltar ao painel</a>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="alert alert-info" style="margin-top: 1rem;"><%= flash %></div>
    <% } %>

    <div class="card" style="margin-top: 1.5rem;">
      <div style="display: flex; justify-content: space-between; align-items: start;">
        <div>
          <h1><%= game.title %></h1>
          <p style="color: var(--text-secondary);"><%= teamPt(game.home_team) %> x <%= teamPt(game.away_team) %></p>
        </div>
        <span class="status-badge status-<%= game.status %>"><%= game.status %></span>
      </div>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin: 1.5rem 0; padding: 1rem; background: var(--bg-secondary); border-radius: 8px;">
        <div style="text-align: center;">
          <div style="font-size: 0.7rem; color: var(--text-muted);">DATA</div>
          <div style="font-weight: 600;"><%= gameDateBR(game.game_date, { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 0.7rem; color: var(--text-muted);">APOSTAS</div>
          <div style="font-weight: 600;"><%= bets.length %></div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 0.7rem; color: var(--text-muted);">PRÊMIO</div>
          <div style="font-weight: 700; color: var(--gold);"><%= formatCents(game.prize_pool_cents) %></div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 0.7rem; color: var(--text-muted);">RESULTADO</div>
          <div style="font-weight: 700; color: var(--accent);">
            <% if (game.home_score !== null) { %>
              <%= game.home_score %> x <%= game.away_score %>
            <% } else { %>
              —
            <% } %>
          </div>
        </div>
      </div>

      <% if (game.home_score === null) { %>
        <div class="card" style="background: var(--bg-secondary); margin-bottom: 1.5rem;">
          <h3 style="margin-bottom: 1rem;">Informar Resultado Manualmente</h3>
          <form method="POST" action="/admin/games/<%= game.id %>/result" style="display: flex; align-items: end; gap: 1rem; flex-wrap: wrap;">
            <div class="form-group" style="margin: 0;">
              <label><%= teamPt(game.home_team) %></label>
              <input type="number" name="home_score" class="form-control" min="0" required style="width: 80px;">
            </div>
            <span style="padding-bottom: 0.75rem; font-weight: 800;">x</span>
            <div class="form-group" style="margin: 0;">
              <label><%= teamPt(game.away_team) %></label>
              <input type="number" name="away_score" class="form-control" min="0" required style="width: 80px;">
            </div>
            <button type="submit" class="btn btn-gold">Finalizar e Distribuir Prêmio</button>
          </form>
        </div>
      <% } else if (game.status === 'closed' && game.home_score !== null) { %>
        <div class="card" style="background: rgba(59, 130, 246, 0.08); border: 1px solid rgba(59, 130, 246, 0.35); margin-bottom: 1.5rem; padding: 1rem;">
          <h3 style="margin-bottom: 0.5rem;">Jogo ao vivo / aguardando apito final</h3>
          <p style="color: var(--text-secondary); font-size: 0.85rem; margin: 0;">
            Placar atual: <strong><%= game.home_score %>×<%= game.away_score %></strong>.
            Quando a API confirmar o fim da partida, o bolão <strong>finaliza sozinho</strong> e calcula os ganhadores.
            O <strong>WhatsApp</strong> para ganhadores só é enviado quando você clicar no botão — após o status mudar para <em>finished</em> e conferir o placar.
          </p>
        </div>
      <% } else if (game.status === 'finished') { %>
        <div class="card" style="background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.35); margin-bottom: 1.5rem;">
          <h3 style="margin-bottom: 0.5rem;">Corrigir placar e recalcular ganhadores</h3>
          <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1rem;">
            Use se o jogo foi encerrado com placar errado. Só funciona enquanto nenhum prêmio foi marcado como pago.
          </p>
          <form method="POST" action="/admin/games/<%= game.id %>/reprocess-result" style="display: flex; align-items: end; gap: 1rem; flex-wrap: wrap;">
            <div class="form-group" style="margin: 0;">
              <label><%= teamPt(game.home_team) %></label>
              <input type="number" name="home_score" class="form-control" min="0" required style="width: 80px;" value="<%= game.home_score %>">
            </div>
            <span style="padding-bottom: 0.75rem; font-weight: 800;">x</span>
            <div class="form-group" style="margin: 0;">
              <label><%= teamPt(game.away_team) %></label>
              <input type="number" name="away_score" class="form-control" min="0" required style="width: 80px;" value="<%= game.away_score %>">
            </div>
            <button type="submit" class="btn btn-gold" onclick="return confirm('Recalcular ganhadores com este placar? Apostas e prêmios serão refeitos.');">
              Corrigir e recalcular
            </button>
          </form>
        </div>
        <% const verifiedWinners = bets.filter(function(b) {
          return b.is_winner && b.home_score_prediction === game.home_score && b.away_score_prediction === game.away_score;
        }); %>
        <% const paidVerifiedWinners = verifiedWinners.filter(function(b) { return b.prize_paid_at; }); %>
        <div class="card" style="background: var(--bg-secondary); border: 1px solid rgba(34, 197, 94, 0.35); margin-bottom: 1.5rem; padding: 1rem;">
          <h3 style="margin-bottom: 0.5rem;">WhatsApp — somente manual</h3>
          <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1rem;">
            O sistema <strong>não envia mais</strong> mensagem de vitória automaticamente.
            Confira o placar <strong><%= game.home_score %>×<%= game.away_score %></strong> antes de enviar.
            Ganhadores conferidos: <strong><%= verifiedWinners.length %></strong> aposta(s).
            <% if (game.results_whatsapp_sent_at) { %>
              <br><span style="color: var(--gold);">Último envio: <%= new Date(game.results_whatsapp_sent_at).toLocaleString('pt-BR') %></span>
            <% } %>
          </p>

          <% if (verifiedWinners.length > 0) { %>
            <form method="POST" action="/admin/games/<%= game.id %>/notify-winners" style="margin-bottom: 1rem;">
              <input type="hidden" name="score_home" value="<%= game.home_score %>">
              <input type="hidden" name="score_away" value="<%= game.away_score %>">
              <label style="display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.85rem; margin-bottom: 0.75rem; cursor: pointer;">
                <input type="checkbox" name="confirm" value="1" required style="margin-top: 0.2rem;">
                <span>Confirmo que o placar final <strong><%= game.home_score %>×<%= game.away_score %></strong> está correto e desejo avisar <strong>somente os <%= verifiedWinners.length %> ganhador(es)</strong> verificados.</span>
              </label>
              <% if (game.results_whatsapp_sent_at) { %>
                <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; margin-bottom: 0.75rem; color: var(--text-muted);">
                  <input type="checkbox" name="force" value="1">
                  Reenviar (já houve envio anterior)
                </label>
              <% } %>
              <button type="submit" class="btn btn-gold">📲 Enviar WhatsApp aos ganhadores</button>
            </form>
          <% } else { %>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">Nenhum ganhador verificado para este placar.</p>
          <% } %>

          <% if (paidVerifiedWinners.length > 0) { %>
            <form method="POST" action="/admin/games/<%= game.id %>/notify-prize-paid" style="margin-bottom: 1rem; padding-top: 1rem; border-top: 1px solid var(--border);">
              <input type="hidden" name="confirm" value="1">
              <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.75rem;">
                <strong><%= paidVerifiedWinners.length %></strong> ganhador(es) com prêmio já marcado como pago no sistema.
              </p>
              <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; margin-bottom: 0.75rem; color: var(--text-muted);">
                <input type="checkbox" name="force" value="1">
                Reenviar se já mandou antes
              </label>
              <button type="submit" class="btn btn-gold" onclick="return confirm('Enviar WhatsApp confirmando PIX pago para <%= paidVerifiedWinners.length %> ganhador(es)?');">
                ✅ Avisar ganhadores — PIX já transferido
              </button>
            </form>
          <% } %>

          <form method="POST" action="/admin/games/<%= game.id %>/notify-correction">
            <input type="hidden" name="confirm" value="1">
            <p style="font-size: 0.82rem; color: var(--text-muted); margin-bottom: 0.5rem;">
              Se alguém recebeu aviso errado (ex.: placar provisório), envie a correção para todos os participantes.
            </p>
            <button type="submit" class="btn btn-outline" onclick="return confirm('Enviar correção de resultado para TODOS os participantes deste bolão?');">
              ⚠️ Enviar correção de resultado a todos
            </button>
          </form>
        </div>
      <% } %>
    </div>

    <h2 class="section-title">Apostas (<%= bets.length %>)</h2>

    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Nome</th>
            <th>Telefone</th>
            <th>CPF</th>
            <th>Placar</th>
            <th>Status</th>
            <th>Prêmio</th>
            <th>Data</th>
          </tr>
        </thead>
        <tbody>
          <% if (bets.length === 0) { %>
            <tr><td colspan="7" style="text-align: center; color: var(--text-muted);">Nenhuma aposta ainda</td></tr>
          <% } %>
          <% bets.forEach(function(bet) { %>
            <tr>
              <td><%= bet.user_name %></td>
              <td><%= bet.phone || '—' %></td>
              <td><%= bet.cpf ? bet.cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4') : '—' %></td>
              <td><strong><%= bet.home_score_prediction %> x <%= bet.away_score_prediction %></strong></td>
              <td>
                <% if (bet.is_winner) { %>
                  <span class="winner-badge">🏆 Ganhador</span>
                <% } else if (game.status === 'finished') { %>
                  Não ganhou
                <% } else { %>
                  Aguardando
                <% } %>
              </td>
              <td>
                <% if (bet.is_winner) { %>
                  <span class="prize-amount"><%= formatCents(bet.prize_amount_cents) %></span>
                <% } else { %>—<% } %>
              </td>
              <td><%= new Date(bet.created_at).toLocaleString('pt-BR') %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>
