<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-admin">
  <%- include('layout') %>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="alert alert-info" style="margin-bottom: 1rem;"><%= flash %></div>
    <% } %>

    <p class="admin-page-intro">
      Taxas conforme as <a href="/regras" target="_blank">regras</a>:
      <strong><%= prizeNetPercent %>%</strong> aos ganhadores (taxa <%= systemFeePercent %>%)
      · sem ganhador, reembolso de <strong><%= noWinnerRefundPercent %>%</strong> (taxa <%= noWinnerFeePercent %>%).
    </p>

    <div class="admin-pay-summary">
      <div class="admin-pay-card">
        <span class="admin-pay-card-label">PIX recebido</span>
        <strong class="admin-pay-card-value admin-pay-card-value--accent"><%= formatCents(finance.totalReceivedCents) %></strong>
      </div>
      <div class="admin-pay-card">
        <span class="admin-pay-card-label">Em bolões ativos</span>
        <strong class="admin-pay-card-value"><%= formatCents(finance.activePoolCents) %></strong>
        <small>Aguardando resultado — taxa ainda não aplicada</small>
      </div>
      <div class="admin-pay-card admin-pay-card--fee">
        <span class="admin-pay-card-label">Taxa retida (realizada)</span>
        <strong class="admin-pay-card-value admin-pay-card-value--fee"><%= formatCents(finance.realizedFeeCents) %></strong>
        <small>
          <%= systemFeePercent %>% com ganhador: <%= formatCents(finance.feeFromWinnersCents) %>
          · <%= noWinnerFeePercent %>% sem ganhador: <%= formatCents(finance.feeFromNoWinnerCents) %>
        </small>
      </div>
      <div class="admin-pay-card admin-pay-card--gold">
        <span class="admin-pay-card-label">A enviar (líquido)</span>
        <strong class="admin-pay-card-value admin-pay-card-value--gold"><%= formatCents(finance.pendingPayoutsCents) %></strong>
        <small>Já com taxa descontada</small>
      </div>
      <div class="admin-pay-card">
        <span class="admin-pay-card-label">Já enviado aos jogadores</span>
        <strong class="admin-pay-card-value"><%= formatCents(finance.paidPayoutsCents) %></strong>
      </div>
    </div>

    <!-- Tabs -->
    <div class="admin-tabs" style="display:flex; gap:0.5rem; margin-bottom:1.5rem; flex-wrap:wrap;">
      <button type="button" class="btn btn-sm tab-btn active" data-tab="pending-pix" onclick="showTab('pending-pix', this)">
        ⏳ PIX Pendentes (<%= pendingPayments.length %>)
      </button>
      <button type="button" class="btn btn-sm tab-btn" data-tab="expired-pix" onclick="showTab('expired-pix', this)">
        ⛔ Expirados (<%= typeof expiredPayments !== 'undefined' ? expiredPayments.length : 0 %>)
      </button>
      <button type="button" class="btn btn-sm tab-btn" data-tab="confirmed-pix" onclick="showTab('confirmed-pix', this)">
        ✅ PIX Confirmados (<%= confirmedPayments.length %>)
      </button>
      <button type="button" class="btn btn-sm tab-btn" data-tab="payouts-pending" onclick="showTab('payouts-pending', this)">
        🏆 Prêmios a Enviar (<%= pendingPayouts.length %>)
      </button>
      <button type="button" class="btn btn-sm tab-btn" data-tab="payouts-paid" onclick="showTab('payouts-paid', this)">
        ✓ Prêmios Pagos (<%= paidPayouts.length %>)
      </button>
    </div>

    <!-- TAB 1: PIX Pendentes -->
    <div class="tab-content" id="tab-pending-pix">
      <h3 style="font-size:0.9rem; color:var(--gold); margin-bottom:0.5rem;">⏳ Aguardando pagamento PIX</h3>
      <p style="font-size:0.75rem; color:var(--text-muted); margin-bottom:0.75rem;">
        Usuários que geraram QR Code mas ainda podem pagar (bolão com apostas abertas)
      </p>

      <% if (pendingPayments.length === 0) { %>
        <div class="alert" style="background:rgba(100,116,139,0.1); border:1px solid var(--border); color:var(--text-secondary); text-align:center;">
          Nenhum pagamento PIX pendente.
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead><tr><th>Jogador</th><th>Telefone</th><th>Jogo</th><th>Valor</th><th>Criado em</th><th>QR</th></tr></thead>
            <tbody>
              <% pendingPayments.forEach(p => { %>
                <tr>
                  <td><strong><%= p.user_name %></strong></td>
                  <td style="font-size:0.8rem;"><%= p.user_phone || '—' %></td>
                  <td style="font-size:0.8rem;"><%= teamPt(p.home_team) %> × <%= teamPt(p.away_team) %></td>
                  <td><strong><%= formatCents(p.amount_cents) %></strong></td>
                  <td style="font-size:0.75rem; color:var(--text-muted);"><%= new Date(p.created_at).toLocaleString('pt-BR') %></td>
                  <td><%= p.qr_code_text ? '✅' : '❌' %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <p style="font-size:0.75rem; color:var(--text-muted); margin-top:0.5rem;">
          Total pendente: <strong><%= formatCents(pendingPayments.reduce((s, p) => s + p.amount_cents, 0)) %></strong>
        </p>
      <% } %>
    </div>

    <!-- TAB: PIX expirados / recusados -->
    <div class="tab-content" id="tab-expired-pix" style="display:none;">
      <h3 style="font-size:0.9rem; color:var(--text-muted); margin-bottom:0.5rem;">⛔ PIX expirados ou recusados</h3>
      <p style="font-size:0.75rem; color:var(--text-muted); margin-bottom:0.75rem;">
        QR Codes gerados após o encerramento das apostas ou pagos tarde demais — <strong>não geram aposta</strong>.
      </p>

      <% if (typeof expiredPayments === 'undefined' || expiredPayments.length === 0) { %>
        <div class="alert" style="background:rgba(100,116,139,0.1); border:1px solid var(--border); color:var(--text-secondary); text-align:center;">
          Nenhum PIX expirado ou recusado recentemente.
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead><tr><th>Jogador</th><th>Jogo</th><th>Valor</th><th>Status</th><th>Atualizado</th></tr></thead>
            <tbody>
              <% expiredPayments.forEach(p => { %>
                <tr>
                  <td><strong><%= p.user_name %></strong></td>
                  <td style="font-size:0.8rem;"><%= teamPt(p.home_team) %> × <%= teamPt(p.away_team) %></td>
                  <td><%= formatCents(p.amount_cents) %></td>
                  <td>
                    <% if (p.status === 'declined') { %>
                      <span class="card-badge closed">Recusado (pago tarde)</span>
                    <% } else { %>
                      <span class="card-badge finished">Expirado</span>
                    <% } %>
                  </td>
                  <td style="font-size:0.75rem; color:var(--text-muted);"><%= new Date(p.updated_at).toLocaleString('pt-BR') %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- TAB 2: PIX Confirmados -->
    <div class="tab-content" id="tab-confirmed-pix" style="display:none;">
      <h3 style="font-size:0.9rem; color:var(--accent); margin-bottom:0.5rem;">✅ Pagamentos PIX confirmados</h3>
      <p style="font-size:0.75rem; color:var(--text-muted); margin-bottom:0.75rem;">Apostas pagas com sucesso</p>

      <% if (confirmedPayments.length === 0) { %>
        <div class="alert" style="background:rgba(100,116,139,0.1); border:1px solid var(--border); color:var(--text-secondary); text-align:center;">
          Nenhum pagamento confirmado ainda.
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead><tr><th>Jogador</th><th>Jogo</th><th>Valor</th><th>Pago em</th></tr></thead>
            <tbody>
              <% confirmedPayments.forEach(p => { %>
                <tr>
                  <td><strong><%= p.user_name %></strong></td>
                  <td style="font-size:0.8rem;"><%= teamPt(p.home_team) %> × <%= teamPt(p.away_team) %></td>
                  <td><strong><%= formatCents(p.amount_cents) %></strong></td>
                  <td style="font-size:0.75rem; color:var(--text-muted);"><%= p.paid_at ? new Date(p.paid_at).toLocaleString('pt-BR') : '—' %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <p style="font-size:0.75rem; color:var(--text-muted); margin-top:0.5rem;">
          Total recebido: <strong><%= formatCents(confirmedPayments.reduce((s, p) => s + p.amount_cents, 0)) %></strong>
        </p>
      <% } %>
    </div>

    <!-- TAB 3: Prêmios a enviar -->
    <div class="tab-content" id="tab-payouts-pending" style="display:none;">
      <h3 style="font-size:0.9rem; color:var(--gold); margin-bottom:0.5rem;">🏆 Prêmios a enviar via PIX</h3>
      <p style="font-size:0.75rem; color:var(--text-muted); margin-bottom:0.75rem;">
        Conferir dados do cadastro e pagar via PIX (QR Code da chave do jogador).
      </p>

      <% if (pendingPayouts.length === 0) { %>
        <div class="alert alert-success" style="text-align:center;">✓ Nenhum prêmio pendente de envio!</div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Jogador</th>
                <th>Chave PIX</th>
                <th>Jogo</th>
                <th>Tipo</th>
                <th>Apostado</th>
                <th>Taxa</th>
                <th>Líquido PIX</th>
                <th>Ação</th>
              </tr>
            </thead>
            <tbody>
              <% pendingPayouts.forEach(p => { %>
                <tr>
                  <td><strong><%= p.user_name %></strong><br><small style="color:var(--text-muted);"><%= p.user_phone || '' %></small></td>
                  <td style="font-size:0.78rem; max-width:130px; word-break:break-all;" title="<%= p.user_pix || '' %>"><%= p.user_pix || '—' %></td>
                  <td style="font-size:0.8rem;"><%= teamPt(p.home_team) %> × <%= teamPt(p.away_team) %></td>
                  <td style="font-size:0.78rem;"><%= p.payoutLabel %></td>
                  <td><%= p.stakeCents > 0 ? formatCents(p.stakeCents) : '—' %></td>
                  <td style="font-size:0.8rem; color:var(--text-muted);">
                    <% if (p.is_winner) { %>
                      <%= p.feeLabel %>
                    <% } else { %>
                      <%= formatCents(p.feeCents) %> <small>(<%= p.feeLabel %>)</small>
                    <% } %>
                  </td>
                  <td class="prize-amount"><strong><%= formatCents(p.prize_amount_cents) %></strong></td>
                  <td>
                    <button
                      type="button"
                      class="btn btn-primary btn-sm btn-payout-review"
                      data-bet-id="<%= p.id %>"
                    >Conferir e pagar</button>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <p style="font-size:0.75rem; color:var(--text-muted); margin-top:0.5rem;">
          Total líquido a enviar: <strong><%= formatCents(finance.pendingPayoutsCents) %></strong>
        </p>
      <% } %>
    </div>

    <!-- TAB 4: Prêmios pagos -->
    <div class="tab-content" id="tab-payouts-paid" style="display:none;">
      <h3 style="font-size:0.9rem; color:var(--accent); margin-bottom:0.5rem;">✓ Prêmios já enviados</h3>

      <% if (typeof paidWinnerGames !== 'undefined' && paidWinnerGames.length > 0) { %>
        <div style="margin-bottom: 1rem; padding: 1rem; background: rgba(34, 197, 94, 0.08); border: 1px solid rgba(34, 197, 94, 0.35); border-radius: 8px;">
          <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.75rem;">
            Avisar ganhadores por WhatsApp que o PIX do prêmio já foi transferido:
          </p>
          <% paidWinnerGames.forEach(function(g) { %>
            <form method="POST" action="/admin/games/<%= g.gameId %>/notify-prize-paid" style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
              <input type="hidden" name="redirect" value="pagamentos">
              <input type="hidden" name="confirm" value="1">
              <span style="font-size: 0.85rem;"><strong><%= g.title %></strong> — <%= g.count %> ganhador(es) pagos</span>
              <label style="font-size: 0.78rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.35rem;">
                <input type="checkbox" name="force" value="1"> Reenviar
              </label>
              <button type="submit" class="btn btn-sm btn-gold" onclick="return confirm('Enviar WhatsApp de PIX pago para <%= g.count %> ganhador(es) de <%= g.title %>?');">
                📲 Confirmar PIX no Zap
              </button>
            </form>
          <% }); %>
        </div>
      <% } %>

      <% if (paidPayouts.length === 0) { %>
        <div class="alert" style="background:rgba(100,116,139,0.1); border:1px solid var(--border); color:var(--text-secondary); text-align:center;">
          Nenhum prêmio pago ainda.
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Jogador</th>
                <th>Chave PIX</th>
                <th>Jogo</th>
                <th>Tipo</th>
                <th>Apostado</th>
                <th>Taxa</th>
                <th>Líquido PIX</th>
                <th>Pago em</th>
                <th>Zap</th>
              </tr>
            </thead>
            <tbody>
              <% paidPayouts.forEach(p => { %>
                <tr>
                  <td><%= p.user_name %></td>
                  <td style="font-size:0.78rem;"><%= p.user_pix || '—' %></td>
                  <td style="font-size:0.8rem;"><%= teamPt(p.home_team) %> × <%= teamPt(p.away_team) %></td>
                  <td style="font-size:0.78rem;"><%= p.payoutLabel %></td>
                  <td><%= p.stakeCents > 0 ? formatCents(p.stakeCents) : '—' %></td>
                  <td style="font-size:0.8rem; color:var(--text-muted);">
                    <% if (p.is_winner) { %>
                      <%= p.feeLabel %>
                    <% } else { %>
                      <%= formatCents(p.feeCents) %> <small>(<%= p.feeLabel %>)</small>
                    <% } %>
                  </td>
                  <td><%= formatCents(p.prize_amount_cents) %></td>
                  <td style="font-size:0.75rem; color:var(--text-muted);"><%= new Date(p.prize_paid_at).toLocaleString('pt-BR') %></td>
                  <td>
                    <% if (p.user_phone) { %>
                      <form method="POST" action="/admin/pagamentos/<%= p.id %>/notify-individual" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-gold" title="Enviar WhatsApp via Baileys">📲</button>
                      </form>
                    <% } else { %>
                      <span style="color:var(--text-muted);">—</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div class="admin-bet-modal admin-payout-modal" id="admin-payout-modal" hidden>
      <div class="admin-bet-modal-backdrop" id="admin-payout-modal-backdrop"></div>
      <div class="admin-bet-modal-dialog admin-payout-modal-dialog" role="dialog" aria-labelledby="admin-payout-modal-title" aria-modal="true">
        <header class="admin-bet-modal-header">
          <div>
            <h2 class="admin-bet-modal-title" id="admin-payout-modal-title">Conferir e pagar</h2>
            <p class="admin-bet-modal-sub" id="admin-payout-modal-sub">Confira se os dados batem com o cadastro antes de transferir.</p>
          </div>
          <button type="button" class="admin-bet-modal-close" id="admin-payout-modal-close" aria-label="Fechar">×</button>
        </header>
        <div class="admin-bet-modal-body admin-payout-modal-body">
          <div id="admin-payout-loading" class="admin-payout-loading">Gerando QR Code PIX…</div>
          <div id="admin-payout-error" class="alert alert-error" style="display:none;"></div>
          <div id="admin-payout-content" style="display:none;">
            <div class="admin-payout-grid">
              <div class="admin-payout-field">
                <span class="admin-payout-label">Jogador</span>
                <strong id="payout-user-name">—</strong>
              </div>
              <div class="admin-payout-field">
                <span class="admin-payout-label">WhatsApp</span>
                <strong id="payout-user-phone">—</strong>
              </div>
              <div class="admin-payout-field admin-payout-field--full">
                <span class="admin-payout-label">Chave PIX (cadastro)</span>
                <strong id="payout-pix-key" class="admin-payout-pix-key">—</strong>
              </div>
              <div class="admin-payout-field">
                <span class="admin-payout-label">Jogo</span>
                <strong id="payout-match">—</strong>
              </div>
              <div class="admin-payout-field">
                <span class="admin-payout-label">Palpite</span>
                <strong id="payout-prediction">—</strong>
              </div>
              <div class="admin-payout-field">
                <span class="admin-payout-label">Tipo</span>
                <strong id="payout-type">—</strong>
              </div>
              <div class="admin-payout-field">
                <span class="admin-payout-label">Valor líquido</span>
                <strong id="payout-amount" class="admin-payout-amount">—</strong>
              </div>
            </div>

            <div class="admin-payout-qr-wrap">
              <p class="admin-payout-qr-title">QR Code PIX — chave do cadastro</p>
              <img id="payout-qr-image" class="admin-payout-qr-image" alt="QR Code PIX para transferência">
              <p class="admin-payout-qr-hint">Escaneie no app do banco. O valor já vem preenchido.</p>
              <button type="button" class="btn btn-outline btn-sm" id="payout-copy-payload">Copiar código PIX</button>
            </div>

            <form method="POST" action="" id="admin-payout-mark-form" class="admin-payout-mark-form">
              <label class="admin-payout-confirm-label">
                <input type="checkbox" id="payout-confirm-check" required>
                Conferi nome, WhatsApp e chave PIX — já transferi este valor
              </label>
              <div class="admin-bet-modal-actions">
                <button type="button" class="btn btn-outline" id="admin-payout-cancel">Fechar</button>
                <button type="submit" class="btn btn-primary" id="payout-mark-paid-btn" disabled>✓ Marcar como pago</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

  <%- include('layout-close') %>

<script>
function showTab(tabId, btn) {
  document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
  document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
  document.getElementById('tab-' + tabId).style.display = 'block';
  btn.classList.add('active');
}

(function () {
  const modal = document.getElementById('admin-payout-modal');
  if (!modal) return;

  const backdrop = document.getElementById('admin-payout-modal-backdrop');
  const closeBtn = document.getElementById('admin-payout-modal-close');
  const cancelBtn = document.getElementById('admin-payout-cancel');
  const loadingEl = document.getElementById('admin-payout-loading');
  const errorEl = document.getElementById('admin-payout-error');
  const contentEl = document.getElementById('admin-payout-content');
  const formEl = document.getElementById('admin-payout-mark-form');
  const confirmCheck = document.getElementById('payout-confirm-check');
  const markBtn = document.getElementById('payout-mark-paid-btn');
  const copyBtn = document.getElementById('payout-copy-payload');
  let currentPayload = '';

  function setField(id, text) {
    const el = document.getElementById(id);
    if (el) el.textContent = text || '—';
  }

  function closeModal() {
    modal.hidden = true;
    document.body.classList.remove('modal-open');
    currentPayload = '';
    if (confirmCheck) confirmCheck.checked = false;
    if (markBtn) markBtn.disabled = true;
  }

  function openModal() {
    modal.hidden = false;
    document.body.classList.add('modal-open');
  }

  function showLoading() {
    loadingEl.style.display = 'block';
    errorEl.style.display = 'none';
    contentEl.style.display = 'none';
  }

  function showError(msg) {
    loadingEl.style.display = 'none';
    contentEl.style.display = 'none';
    errorEl.style.display = 'block';
    errorEl.textContent = msg;
  }

  function showContent(data) {
    loadingEl.style.display = 'none';
    errorEl.style.display = 'none';
    contentEl.style.display = 'block';

    setField('payout-user-name', data.userName);
    setField('payout-user-phone', data.userPhone || data.userPhoneRaw || '—');
    setField('payout-pix-key', data.pixKey);
    setField('payout-match', data.match);
    setField('payout-prediction', data.prediction);
    setField('payout-type', data.payoutLabel);
    setField('payout-amount', data.amountFormatted);

    const qrImg = document.getElementById('payout-qr-image');
    if (qrImg) qrImg.src = data.qrImage;

    currentPayload = data.pixPayload || '';
    if (formEl) formEl.action = '/admin/pagamentos/' + data.betId + '/pagar';
  }

  async function loadPayout(betId) {
    showLoading();
    openModal();
    try {
      const res = await fetch('/admin/pagamentos/' + betId + '/pix-payout', {
        credentials: 'same-origin',
        headers: { Accept: 'application/json' },
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Erro ao carregar');
      showContent(data);
    } catch (err) {
      showError(err.message || 'Não foi possível gerar o QR PIX');
    }
  }

  document.querySelectorAll('.btn-payout-review').forEach((btn) => {
    btn.addEventListener('click', () => loadPayout(btn.dataset.betId));
  });

  if (confirmCheck && markBtn) {
    confirmCheck.addEventListener('change', () => {
      markBtn.disabled = !confirmCheck.checked;
    });
  }

  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      if (!currentPayload) return;
      navigator.clipboard.writeText(currentPayload).then(() => {
        copyBtn.textContent = 'Copiado!';
        setTimeout(() => { copyBtn.textContent = 'Copiar código PIX'; }, 2500);
      });
    });
  }

  backdrop?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);
  cancelBtn?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });
})();
</script>

<style>
.tab-btn { background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary); cursor: pointer; padding: 0.4rem 0.75rem; border-radius: 6px; font-size: 0.8rem; }
.tab-btn.active { background: var(--gold); color: #000; border-color: var(--gold); font-weight: 600; }
.tab-btn:hover:not(.active) { border-color: var(--text-muted); }

.admin-pay-summary {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  gap: 0.65rem;
  margin-bottom: 1.35rem;
}

.admin-pay-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0.8rem 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.admin-pay-card--fee {
  border-color: rgba(16, 185, 129, 0.35);
}

.admin-pay-card--gold {
  border-color: rgba(245, 158, 11, 0.35);
}

.admin-pay-card-label {
  font-size: 0.72rem;
  color: var(--text-muted);
}

.admin-pay-card-value {
  font-size: 1.05rem;
  font-weight: 800;
  color: var(--text-primary);
}

.admin-pay-card-value--accent { color: var(--accent); }
.admin-pay-card-value--fee { color: #10b981; }
.admin-pay-card-value--gold { color: var(--gold); }

.admin-pay-card small {
  font-size: 0.65rem;
  color: var(--text-muted);
  line-height: 1.35;
  margin-top: 0.15rem;
}

.admin-payout-modal-dialog {
  max-width: 480px;
}

.admin-payout-loading {
  text-align: center;
  padding: 1.5rem;
  color: var(--text-muted);
  font-size: 0.88rem;
}

.admin-payout-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.65rem 0.85rem;
  margin-bottom: 1rem;
}

.admin-payout-field {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  min-width: 0;
}

.admin-payout-field--full {
  grid-column: 1 / -1;
}

.admin-payout-label {
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--text-muted);
}

.admin-payout-pix-key {
  word-break: break-all;
  font-size: 0.88rem;
  color: #4ade80;
}

.admin-payout-amount {
  color: var(--gold);
  font-size: 1.05rem;
}

.admin-payout-qr-wrap {
  text-align: center;
  padding: 0.85rem;
  margin-bottom: 1rem;
  border-radius: 12px;
  background: rgba(15, 23, 42, 0.45);
  border: 1px solid rgba(34, 197, 94, 0.25);
}

.admin-payout-qr-title {
  margin: 0 0 0.65rem;
  font-size: 0.82rem;
  font-weight: 700;
  color: #4ade80;
}

.admin-payout-qr-image {
  width: 220px;
  height: 220px;
  border-radius: 10px;
  background: #fff;
  padding: 0.35rem;
}

.admin-payout-qr-hint {
  margin: 0.55rem 0 0.65rem;
  font-size: 0.75rem;
  color: var(--text-muted);
}

.admin-payout-confirm-label {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  font-size: 0.82rem;
  color: var(--text-secondary);
  line-height: 1.45;
  margin-bottom: 0.85rem;
  cursor: pointer;
}

.admin-payout-confirm-label input {
  margin-top: 0.2rem;
  flex-shrink: 0;
}

.admin-payout-mark-form {
  border-top: 1px solid var(--border);
  padding-top: 0.85rem;
}
</style>
</body>
</html>
