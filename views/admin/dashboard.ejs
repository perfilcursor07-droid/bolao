<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-admin">
  <%- include('layout') %>

    <!-- Header com saudação -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.75rem;">
      <div>
        <h1 style="font-size:1.4rem; margin-bottom:0.2rem;">📊 Dashboard</h1>
        <p style="font-size:0.8rem; color:var(--text-muted);">Visão geral do sistema</p>
      </div>
      <div style="display:flex; gap:0.5rem;">
        <a href="/admin/games/new" class="btn btn-primary btn-sm">+ Novo Jogo</a>
        <a href="/admin/copa" class="btn btn-sm" style="background:var(--bg-card); border:1px solid var(--border);">🌍 Copa</a>
      </div>
    </div>

    <!-- Configuração do valor do bolão -->
    <div class="admin-settings-card">
      <div class="admin-settings-head">
        <div>
          <h2>⚙️ Valor do bolão</h2>
          <p>Define o valor padrão por placar em novos jogos e na importação da Copa.</p>
        </div>
        <div class="admin-settings-current">
          <span>Atual</span>
          <strong><%= formatCents(Math.round(parseFloat(defaultEntryFee) * 100)) %></strong>
        </div>
      </div>

      <% if (settingsSaved) { %>
        <div class="alert alert-success">Valor padrão atualizado com sucesso.</div>
      <% } %>
      <% if (settingsError) { %>
        <div class="alert alert-error"><%= settingsError %></div>
      <% } %>

      <form method="POST" action="/admin/settings/entry-fee" class="admin-settings-form">
        <label for="default_entry_fee">Valor padrão por placar (R$)</label>
        <div class="admin-settings-row">
          <input
            type="number"
            id="default_entry_fee"
            name="entry_fee"
            class="form-control"
            step="0.01"
            min="1"
            required
            value="<%= defaultEntryFee %>"
          >
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
        <small class="admin-settings-hint">
          Jogos já criados mantêm o valor individual. Altere em cada partida se precisar.
        </small>
      </form>
    </div>

    <!-- Stats cards melhoradas -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:0.75rem; margin-bottom:2rem;">
      <div style="background:linear-gradient(135deg, rgba(16,185,129,0.15), rgba(16,185,129,0.05)); border:1px solid rgba(16,185,129,0.3); border-radius:12px; padding:1rem; text-align:center;">
        <div style="font-size:1.5rem; font-weight:800; color:#10b981;"><%= formatCents(stats.total_revenue) %></div>
        <div style="font-size:0.75rem; color:var(--text-muted); margin-top:0.25rem;">💰 Receita Total</div>
      </div>
      <div style="background:linear-gradient(135deg, rgba(245,158,11,0.15), rgba(245,158,11,0.05)); border:1px solid rgba(245,158,11,0.3); border-radius:12px; padding:1rem; text-align:center;">
        <div style="font-size:1.5rem; font-weight:800; color:#f59e0b;"><%= formatCents(stats.total_prizes) %></div>
        <div style="font-size:0.75rem; color:var(--text-muted); margin-top:0.25rem;">🏆 Prêmios Pagos</div>
      </div>
      <div style="background:linear-gradient(135deg, rgba(59,130,246,0.15), rgba(59,130,246,0.05)); border:1px solid rgba(59,130,246,0.3); border-radius:12px; padding:1rem; text-align:center;">
        <div style="font-size:1.5rem; font-weight:800; color:#3b82f6;"><%= stats.total_bets %></div>
        <div style="font-size:0.75rem; color:var(--text-muted); margin-top:0.25rem;">🎟️ Apostas</div>
      </div>
      <div style="background:linear-gradient(135deg, rgba(139,92,246,0.15), rgba(139,92,246,0.05)); border:1px solid rgba(139,92,246,0.3); border-radius:12px; padding:1rem; text-align:center;">
        <div style="font-size:1.5rem; font-weight:800; color:#8b5cf6;"><%= stats.total_users %></div>
        <div style="font-size:0.75rem; color:var(--text-muted); margin-top:0.25rem;">👥 Usuários</div>
      </div>
      <div style="background:linear-gradient(135deg, rgba(236,72,153,0.15), rgba(236,72,153,0.05)); border:1px solid rgba(236,72,153,0.3); border-radius:12px; padding:1rem; text-align:center;">
        <div style="font-size:1.5rem; font-weight:800; color:#ec4899;"><%= stats.total_games %></div>
        <div style="font-size:0.75rem; color:var(--text-muted); margin-top:0.25rem;">⚽ Jogos</div>
      </div>
      <div style="background:linear-gradient(135deg, rgba(20,184,166,0.15), rgba(20,184,166,0.05)); border:1px solid rgba(20,184,166,0.3); border-radius:12px; padding:1rem; text-align:center;">
        <div style="font-size:1.5rem; font-weight:800; color:#14b8a6;"><%= stats.total_winners %></div>
        <div style="font-size:0.75rem; color:var(--text-muted); margin-top:0.25rem;">🎉 Ganhadores</div>
      </div>
    </div>

    <!-- Resumo financeiro rápido -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:0.75rem; margin-bottom:2rem;">
      <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:10px; padding:1rem;">
        <div style="font-size:0.8rem; color:var(--text-muted); margin-bottom:0.3rem;">Lucro estimado (15%)</div>
        <div style="font-size:1.2rem; font-weight:700; color:#10b981;"><%= formatCents(Math.floor(stats.total_revenue * 0.15)) %></div>
      </div>
      <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:10px; padding:1rem;">
        <div style="font-size:0.8rem; color:var(--text-muted); margin-bottom:0.3rem;">Ticket médio</div>
        <div style="font-size:1.2rem; font-weight:700; color:var(--text-primary);"><%= stats.total_bets > 0 ? formatCents(Math.floor(stats.total_revenue / stats.total_bets)) : 'R$ 0' %></div>
      </div>
    </div>

    <!-- Jogos em destaque / abertos -->
    <% if (featured.length > 0) { %>
      <div style="margin-bottom:1.5rem;">
        <h2 style="font-size:1rem; margin-bottom:0.75rem;">⭐ Jogos em Destaque</h2>
        <div style="display:grid; gap:0.5rem;">
          <% featured.forEach(g => { %>
            <a href="/admin/games/<%= g.id %>" style="display:flex; justify-content:space-between; align-items:center; padding:0.75rem; background:var(--bg-card); border:1px solid rgba(245,158,11,0.3); border-radius:8px; text-decoration:none; color:inherit;">
              <div>
                <strong style="font-size:0.85rem;"><%= teamPt(g.home_team) %> × <%= teamPt(g.away_team) %></strong>
                <div style="font-size:0.7rem; color:var(--text-muted);"><%= gameDateBR(g.game_date, { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
              </div>
              <div style="text-align:right;">
                <div style="font-size:0.85rem; font-weight:700; color:var(--gold);"><%= g.total_bets %> apostas</div>
                <div style="font-size:0.7rem; color:var(--text-muted);"><%= formatCents(g.prize_pool_cents) %></div>
              </div>
            </a>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Últimos ganhadores -->
    <% if (recentWinners.length > 0) { %>
      <div style="margin-bottom:1.5rem;">
        <h2 style="font-size:1rem; margin-bottom:0.75rem;">🏆 Últimos Ganhadores</h2>
        <div class="table-container">
          <table>
            <thead>
              <tr><th>Jogador</th><th>Jogo</th><th>Placar</th><th>Prêmio</th></tr>
            </thead>
            <tbody>
              <% recentWinners.forEach(w => { %>
                <tr>
                  <td><strong><%= w.user_name %></strong></td>
                  <td style="font-size:0.8rem;"><%= teamPt(w.home_team) %> × <%= teamPt(w.away_team) %></td>
                  <td><strong><%= w.home_score_prediction %>×<%= w.away_score_prediction %></strong></td>
                  <td class="prize-amount"><%= formatCents(w.prize_amount_cents) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <!-- Todos os jogos recentes -->
    <div>
      <h2 style="font-size:1rem; margin-bottom:0.75rem;">📋 Jogos Recentes</h2>
      <div style="display:grid; gap:0.5rem;">
        <% others.slice(0, 10).forEach(g => { %>
          <a href="/admin/games/<%= g.id %>" style="display:flex; justify-content:space-between; align-items:center; padding:0.6rem 0.75rem; background:var(--bg-card); border:1px solid var(--border); border-radius:8px; text-decoration:none; color:inherit;">
            <div>
              <strong style="font-size:0.8rem;"><%= teamPt(g.home_team) %> × <%= teamPt(g.away_team) %></strong>
              <div style="font-size:0.7rem; color:var(--text-muted);"><%= gameDateBR(g.game_date, { day: '2-digit', month: 'short', year: 'numeric' }) %> · <%= g.status %></div>
            </div>
            <div style="text-align:right;">
              <span style="font-size:0.8rem;"><%= g.total_bets %> apostas</span>
            </div>
          </a>
        <% }); %>
      </div>
      <% if (others.length > 10) { %>
        <a href="/admin/partidas" style="display:block; text-align:center; margin-top:0.75rem; font-size:0.8rem; color:var(--accent);">Ver todos →</a>
      <% } %>
    </div>

  </main>
</div>
</body>
</html>
