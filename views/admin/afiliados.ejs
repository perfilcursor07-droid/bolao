<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-admin">
  <%- include('layout') %>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (updated) { %>
      <div class="alert alert-success">Status atualizado: <%= updated %></div>
    <% } %>
    <% if (paid) { %>
      <div class="alert alert-success">Saque registrado: <%= formatCents(paid) %></div>
    <% } %>

    <p class="admin-page-intro">Afiliados ganham comissão na 1ª aposta PIX paga de cada indicado + bônus por metas. Pagamentos via PIX manualmente.</p>

    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Afiliado</th>
            <th>Código</th>
            <th>Status</th>
            <th>Indicados</th>
            <th>Pagos</th>
            <th>Saldo</th>
            <th>Total ganho</th>
            <th>PIX</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (affiliates.length === 0) { %>
            <tr><td colspan="9" style="text-align:center;color:var(--text-muted);">Nenhum afiliado cadastrado</td></tr>
          <% } %>
          <% affiliates.forEach(function(a) { %>
            <tr>
              <td>
                <strong><%= a.name %></strong><br>
                <small style="color:var(--text-muted);"><%= a.email || a.phone || '—' %></small>
              </td>
              <td><code><%= a.code %></code></td>
              <td>
                <% if (a.status === 'active') { %>
                  <span class="card-badge open">Ativo</span>
                <% } else if (a.status === 'pending') { %>
                  <span class="card-badge closed">Pendente</span>
                <% } else { %>
                  <span class="card-badge finished"><%= a.status %></span>
                <% } %>
              </td>
              <td><%= a.referral_count %></td>
              <td><%= a.total_paid_referrals %></td>
              <td><strong style="color:#4ade80;"><%= formatCents(a.balance_cents) %></strong></td>
              <td><%= formatCents(a.total_earned_cents) %></td>
              <td style="font-size:0.75rem;max-width:120px;word-break:break-all;"><%= a.cpf || '—' %></td>
              <td>
                <div class="admin-inline-actions">
                  <% if (a.status === 'pending') { %>
                    <form method="POST" action="/admin/afiliados/<%= a.id %>/status" style="display:inline;">
                      <input type="hidden" name="status" value="active">
                      <button type="submit" class="btn btn-accent btn-sm">Aprovar</button>
                    </form>
                    <form method="POST" action="/admin/afiliados/<%= a.id %>/status" style="display:inline;">
                      <input type="hidden" name="status" value="rejected">
                      <button type="submit" class="btn btn-outline btn-sm">Recusar</button>
                    </form>
                  <% } %>
                  <% if (a.status === 'active' && a.balance_cents > 0) { %>
                    <form method="POST" action="/admin/afiliados/<%= a.id %>/pagar" onsubmit="return confirm('Confirmar pagamento de <%= formatCents(a.balance_cents) %> via PIX para <%= a.name %>?');">
                      <button type="submit" class="btn btn-gold btn-sm">Pagar saldo</button>
                    </form>
                  <% } %>
                  <% if (a.status === 'active') { %>
                    <form method="POST" action="/admin/afiliados/<%= a.id %>/status">
                      <input type="hidden" name="status" value="suspended">
                      <button type="submit" class="btn btn-outline btn-sm">Suspender</button>
                    </form>
                  <% } %>
                  <% if (a.status === 'suspended') { %>
                    <form method="POST" action="/admin/afiliados/<%= a.id %>/status">
                      <input type="hidden" name="status" value="active">
                      <button type="submit" class="btn btn-accent btn-sm">Reativar</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

  <%- include('layout-close') %>
</body>
</html>
