<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Pix</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-auth page-login page-register">
  <%- include('partials/header') %>

  <main class="auth-shell">
    <div class="auth-shell-bg" aria-hidden="true">
      <span class="auth-orb auth-orb-1"></span>
      <span class="auth-orb auth-orb-2"></span>
    </div>

    <div class="auth-shell-grid auth-shell-grid--register">
      <section class="auth-showcase">
        <a href="/" class="auth-showcase-brand" aria-label="Bolão Pix — início">
          <%- include('partials/brand-wordmark') %>
        </a>
        <h1 class="auth-showcase-headline">
          Crie sua conta.<br>
          <span class="text-gradient">Aposte e ganhe.</span>
        </h1>
        <p class="auth-showcase-text">
          Cadastro gratuito para acompanhar apostas, pagar via PIX e receber prêmios na sua chave cadastrada.
        </p>
        <ul class="auth-benefits">
          <li>
            <span class="auth-benefit-icon">📋</span>
            <span>Histórico completo de apostas e resultados</span>
          </li>
          <li>
            <span class="auth-benefit-icon">💳</span>
            <span>Pagamento e prêmio via PIX</span>
          </li>
          <li>
            <span class="auth-benefit-icon">🔗</span>
            <span>Opção de virar afiliado e ganhar por indicação</span>
          </li>
        </ul>
      </section>

      <section class="auth-panel">
        <div class="auth-card auth-card-login auth-card-register">
          <div class="auth-card-header">
            <h2>Criar conta grátis</h2>
            <p class="subtitle">Leva menos de 1 minuto — e-mail, senha e chave PIX</p>
          </div>

          <% if (error) { %>
            <div class="alert alert-error" role="alert">
              <span class="alert-icon">!</span>
              <%= error %>
            </div>
          <% } %>

          <form method="POST" action="/register" class="auth-form" id="register-form">
            <div class="auth-form-grid">
              <div class="form-group auth-field auth-form-span-2">
                <label for="name">Nome completo</label>
                <div class="auth-input-wrap">
                  <span class="auth-input-icon" aria-hidden="true">👤</span>
                  <input type="text" id="name" name="name" class="form-control auth-input" required placeholder="Seu nome" autocomplete="name">
                </div>
              </div>

              <div class="form-group auth-field auth-form-span-2">
                <label for="email">E-mail</label>
                <div class="auth-input-wrap">
                  <span class="auth-input-icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 8l8 5 8-5M4 8v10h16V8"/></svg>
                  </span>
                  <input type="email" id="email" name="email" class="form-control auth-input" required placeholder="seu@email.com" autocomplete="email">
                </div>
              </div>

              <div class="form-group auth-field">
                <label for="phone">WhatsApp</label>
                <div class="auth-input-wrap">
                  <span class="auth-input-icon" aria-hidden="true">📱</span>
                  <input type="tel" id="phone" name="phone" class="form-control auth-input" placeholder="(00) 00000-0000" autocomplete="tel">
                </div>
              </div>

              <div class="form-group auth-field">
                <label for="cpf">Chave PIX <small>(prêmio)</small></label>
                <div class="auth-input-wrap">
                  <span class="auth-input-icon" aria-hidden="true">💰</span>
                  <input type="text" id="cpf" name="cpf" class="form-control auth-input" required placeholder="CPF, tel. ou e-mail" autocomplete="off">
                </div>
              </div>

              <div class="form-group auth-field">
                <label for="password">Senha</label>
                <div class="auth-input-wrap">
                  <span class="auth-input-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
                  </span>
                  <input type="password" id="password" name="password" class="form-control auth-input" required placeholder="Mín. 6 caracteres" minlength="6" autocomplete="new-password">
                </div>
              </div>

              <div class="form-group auth-field">
                <label for="password_confirm">Confirmar senha</label>
                <div class="auth-input-wrap">
                  <span class="auth-input-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
                  </span>
                  <input type="password" id="password_confirm" name="password_confirm" class="form-control auth-input" required placeholder="Repita a senha" minlength="6" autocomplete="new-password">
                </div>
              </div>
            </div>

            <button type="submit" class="btn btn-accent btn-block auth-submit auth-submit--register" id="btn-register">
              Criar minha conta
            </button>
          </form>

          <div class="auth-divider"><span>ou</span></div>

          <a href="/" class="auth-guest-card">
            <span class="auth-guest-icon">⚡</span>
            <span class="auth-guest-copy">
              <strong>Participar sem cadastro</strong>
              <small>Só nome, WhatsApp e PIX — aposte agora</small>
            </span>
            <span class="auth-guest-arrow" aria-hidden="true">→</span>
          </a>

          <p class="auth-footer">
            Já tem conta? <a href="/login">Entrar</a>
          </p>
        </div>
      </section>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    const phoneInput = document.getElementById('phone');
    phoneInput.addEventListener('input', function (e) {
      let v = e.target.value.replace(/\D/g, '');
      if (v.length > 11) v = v.slice(0, 11);
      if (v.length > 10) v = v.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
      else if (v.length > 6) v = v.replace(/(\d{2})(\d{4,5})(\d{0,4})/, '($1) $2-$3');
      else if (v.length > 2) v = v.replace(/(\d{2})(\d{0,5})/, '($1) $2');
      e.target.value = v;
    });

    document.getElementById('register-form').addEventListener('submit', function (e) {
      const password = document.getElementById('password').value;
      const confirm = document.getElementById('password_confirm').value;
      if (password !== confirm) {
        e.preventDefault();
        alert('As senhas não coincidem.');
      }
    });
  </script>
</body>
</html>
