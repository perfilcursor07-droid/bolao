<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-home">
  <%- include('partials/header') %>

  <!-- Hero -->
  <section class="hero-twin" aria-label="Apresentação do bolão">
    <div class="hero-twin-inner">
      <p class="hero-twin-kicker">Bolão online · pague com PIX</p>

      <h1 class="hero-twin-title">
        Acerte o placar. <span class="hero-twin-win">Ganhe.</span>
      </h1>

      <p class="hero-twin-sub">Pague no PIX, acerte o placar e leve o prêmio.</p>

      <div class="hero-twin-flow" aria-label="Como funciona">
        <span class="hero-twin-flow-item">🎯 Placar</span>
        <span class="hero-twin-flow-sep" aria-hidden="true"></span>
        <span class="hero-twin-flow-item">💳 PIX</span>
        <span class="hero-twin-flow-sep" aria-hidden="true"></span>
        <span class="hero-twin-flow-item hero-twin-flow-item--accent">🏆 Prêmio</span>
      </div>

      <p id="home-refresh-status" class="home-refresh-status hero-twin-live" aria-live="polite">
        <span class="home-refresh-dot" aria-hidden="true"></span>
        <span class="home-refresh-text">Atualização automática ativa</span>
      </p>
    </div>
  </section>

  <div class="container home-container">
    <div
      id="home-dynamic"
      class="home-dynamic"
      data-has-live="<%= typeof hasLiveGames !== 'undefined' && hasLiveGames ? '1' : '0' %>"
    >
      <%- include('partials/home-dynamic') %>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="/js/featured-bets.js" defer></script>
  <script src="/js/home-refresh.js" defer></script>
</body>
</html>
