<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-home">
  <%- include('partials/header') %>

  <!-- Hero -->
  <section class="hero-compact">
    <div class="hero-compact-inner">
      <h1>Acerte o placar. <span class="text-gradient">Ganhe.</span></h1>
      <div class="hero-flow" aria-label="Como funciona">
        <span class="hero-flow-item"><span class="hero-flow-ico">🎯</span> Placar</span>
        <span class="hero-flow-sep" aria-hidden="true"></span>
        <span class="hero-flow-item"><span class="hero-flow-ico">💳</span> PIX</span>
        <span class="hero-flow-sep" aria-hidden="true"></span>
        <span class="hero-flow-item hero-flow-item--accent"><span class="hero-flow-ico">🏆</span> Prêmio</span>
      </div>
      <p id="home-refresh-status" class="home-refresh-status" aria-live="polite">
        <span class="home-refresh-dot" aria-hidden="true"></span>
        <span class="home-refresh-text">Atualização automática ativa</span>
      </p>
    </div>
  </section>

  <div class="container home-container">
    <div
      id="home-dynamic"
      class="home-dynamic"
      data-has-live="<%= typeof hasLiveGames !== 'undefined' && hasLiveGames ? '1' : '0' %>"
    >
      <%- include('partials/home-dynamic') %>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="/js/home-refresh.js" defer></script>
</body>
</html>
