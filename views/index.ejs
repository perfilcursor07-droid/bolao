<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Pix</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-home">
  <%- include('partials/header') %>

  <% const hs = typeof heroStats !== 'undefined' ? heroStats : { paidPrizesCents: 0, paidWinners: 0, activePoolCents: 0, openGamesCount: 0, totalBets: 0 }; %>
  <% const showPaid = hs.paidPrizesCents > 0; %>
  <% const prizeHighlight = showPaid ? hs.paidPrizesCents : hs.activePoolCents; %>

  <section class="hero-twin" aria-label="Apresentação do bolão">
    <div class="hero-twin-inner">
      <p class="hero-twin-kicker">
        <span class="hero-twin-kicker-pix">PIX</span>
        <span class="hero-twin-kicker-dot" aria-hidden="true">·</span>
        <span>bolão online</span>
      </p>
      <h1 class="hero-twin-title">
        Acerte o placar. <span class="hero-twin-win">Ganhe.</span>
      </h1>

      <div class="hero-twin-stats" aria-label="Destaques do bolão">
        <div class="hero-twin-stat hero-twin-stat--prize">
          <span class="hero-twin-stat-icon" aria-hidden="true">🏆</span>
          <div class="hero-twin-stat-body">
            <strong class="hero-twin-stat-value"><%= formatCents(prizeHighlight) %></strong>
            <span class="hero-twin-stat-label"><%= showPaid ? 'pagos' : 'no ar' %></span>
          </div>
        </div>
        <% if (hs.paidWinners > 0) { %>
          <div class="hero-twin-stat">
            <span class="hero-twin-stat-icon" aria-hidden="true">✓</span>
            <div class="hero-twin-stat-body">
              <strong class="hero-twin-stat-value"><%= hs.paidWinners %></strong>
              <span class="hero-twin-stat-label">ganhadores</span>
            </div>
          </div>
        <% } %>
        <% if (hs.openGamesCount > 0) { %>
          <div class="hero-twin-stat">
            <span class="hero-twin-stat-icon" aria-hidden="true">⚽</span>
            <div class="hero-twin-stat-body">
              <strong class="hero-twin-stat-value"><%= hs.openGamesCount %></strong>
              <span class="hero-twin-stat-label">abertos</span>
            </div>
          </div>
        <% } %>
      </div>

      <div class="hero-twin-flow" aria-label="Como funciona">
        <span class="hero-twin-flow-item">🎯 Placar</span>
        <span class="hero-twin-flow-sep" aria-hidden="true"></span>
        <span class="hero-twin-flow-item">💳 PIX</span>
        <span class="hero-twin-flow-sep" aria-hidden="true"></span>
        <span class="hero-twin-flow-item hero-twin-flow-item--accent">🏆 Prêmio</span>
      </div>
    </div>
  </section>

  <div class="container home-container">
    <div
      id="home-dynamic"
      class="home-dynamic"
      data-has-live="<%= typeof hasLiveGames !== 'undefined' && hasLiveGames ? '1' : '0' %>"
    >
      <%- include('partials/home-dynamic') %>
    </div>
  </div>

  <div id="featured-bets-modal" class="bets-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="bets-modal-title">
    <div class="bets-modal-backdrop"></div>
    <div class="bets-modal-dialog">
      <header class="bets-modal-header">
        <div>
          <h2 id="bets-modal-title" class="bets-modal-title">Apostas registradas</h2>
          <p class="bets-modal-match"></p>
          <p class="bets-modal-count"></p>
        </div>
        <button type="button" class="bets-modal-close" aria-label="Fechar">✕</button>
      </header>
      <div class="bets-modal-body"></div>
    </div>
  </div>

  <%- include('partials/finished-bolao-modal') %>

  <%- include('partials/footer') %>
  <script src="/js/featured-bets.js" defer></script>
  <script src="/js/finished-boloes.js" defer></script>
  <script src="/js/home-refresh.js" defer></script>
</body>
</html>
