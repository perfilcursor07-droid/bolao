<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-payments">
  <%- include('partials/header') %>

  <div class="container page-shell">
    <header class="page-head">
      <h1>Meus Pagamentos</h1>
      <p>Acompanhe seus PIX e confirme suas apostas</p>
    </header>

    <% if (typeof pendingPayments !== 'undefined' && pendingPayments.length > 0) { %>
      <div class="payments-pending-alert">
        <div class="payments-pending-alert-icon" aria-hidden="true">⏳</div>
        <div class="payments-pending-alert-body">
          <strong>
            <%= pendingPayments.length %> PIX pendente<%= pendingPayments.length !== 1 ? 's' : '' %>
          </strong>
          <p>Pague para confirmar suas apostas. O bolão só entra após o pagamento.</p>
          <a href="/payment/<%= pendingPayments[0].id %>" class="btn btn-gold btn-sm">
            Pagar agora — <%= formatCents(pendingPayments[0].amount_cents) %>
          </a>
        </div>
      </div>
    <% } %>

    <% if (payments.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">💳</div>
        <p>Nenhum pagamento encontrado.</p>
        <a href="/" class="btn btn-primary btn-block" style="margin-top: 1rem; max-width: 280px; margin-left: auto; margin-right: auto;">Ver jogos abertos</a>
      </div>
    <% } else { %>
      <div class="bets-list">
        <% payments.forEach(function(payment) { %>
          <div class="bet-card-mobile">
            <div class="bet-card-top">
              <strong><%= payment.title %></strong>
              <% if (payment.status === 'paid') { %>
                <span class="status-tag" style="background: #d4edda; color: #155724;">✅ Pago</span>
              <% } else if (payment.status === 'pending') { %>
                <span class="status-tag waiting">⏳ Pendente</span>
              <% } else if (payment.status === 'cancelled') { %>
                <span class="status-tag lost">❌ Cancelado</span>
              <% } else { %>
                <span class="status-tag"><%= payment.status %></span>
              <% } %>
            </div>
            <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem;">
              <%= teamPt(payment.home_team) %> × <%= teamPt(payment.away_team) %>
            </p>
            <div class="bet-card-scores">
              <div>
                <small>Valor</small>
                <strong><%= formatCents(payment.amount_cents) %></strong>
              </div>
              <div>
                <small>Data</small>
                <strong><%= new Date(payment.created_at).toLocaleDateString('pt-BR') %></strong>
              </div>
            </div>
            <% if (payment.status === 'pending' && payment.qr_code_text) { %>
              <a href="/payment/<%= payment.id %>" class="btn btn-primary btn-block" style="margin-top: 0.75rem;">
                💰 Pagar agora
              </a>
            <% } else if (payment.status === 'paid') { %>
              <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem; text-align: center;">
                Pago em <%= payment.paid_at ? new Date(payment.paid_at).toLocaleDateString('pt-BR', {day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'}) : '—' %>
              </p>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
