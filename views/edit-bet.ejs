<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <div class="container home-container">
    <a href="/games/<%= bet.game_id %>" class="back-link">← Voltar</a>

    <div class="card" style="max-width:400px; margin:0 auto;">
      <h1 style="font-size:1.2rem; margin-bottom:0.5rem;">✏️ Editar Placar</h1>
      <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:1.5rem;">
        <%= bet.title %> — <%= teamPt(bet.home_team) %> × <%= teamPt(bet.away_team) %>
      </p>

      <form method="POST" action="/games/<%= bet.game_id %>/bets/<%= bet.id %>/edit">
        <div class="placar-picker-card" style="margin-bottom:1.5rem;">
          <div class="placar-picker-teams">
            <div class="placar-picker-side">
              <span class="placar-picker-team-name"><%= teamPt(bet.home_team) %></span>
              <div class="placar-picker-controls">
                <button type="button" class="pbtn" onclick="adj('home',-1)">−</button>
                <span class="placar-picker-num" id="cur-home"><%= bet.home_score_prediction %></span>
                <button type="button" class="pbtn" onclick="adj('home',1)">+</button>
              </div>
            </div>
            <div class="placar-picker-x">×</div>
            <div class="placar-picker-side">
              <span class="placar-picker-team-name"><%= teamPt(bet.away_team) %></span>
              <div class="placar-picker-controls">
                <button type="button" class="pbtn" onclick="adj('away',-1)">−</button>
                <span class="placar-picker-num" id="cur-away"><%= bet.away_score_prediction %></span>
                <button type="button" class="pbtn" onclick="adj('away',1)">+</button>
              </div>
            </div>
          </div>
        </div>

        <input type="hidden" name="home_score" id="input-home" value="<%= bet.home_score_prediction %>">
        <input type="hidden" name="away_score" id="input-away" value="<%= bet.away_score_prediction %>">

        <button type="submit" class="btn btn-gold btn-block btn-xl">Salvar alteração</button>
        <a href="/games/<%= bet.game_id %>" class="btn btn-secondary btn-block" style="margin-top:0.5rem;">Cancelar</a>
      </form>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    let h = <%= bet.home_score_prediction %>, a = <%= bet.away_score_prediction %>;
    function adj(side, d) {
      if (side === 'home') { h = Math.max(0, Math.min(20, h + d)); document.getElementById('cur-home').textContent = h; document.getElementById('input-home').value = h; }
      else { a = Math.max(0, Math.min(20, a + d)); document.getElementById('cur-away').textContent = a; document.getElementById('input-away').value = a; }
    }
  </script>
</body>
</html>
