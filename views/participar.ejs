<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= teamPt(game.home_team) %> × <%= teamPt(game.away_team) %> | Bolão</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-participar">
  <%- include('partials/header') %>

  <main class="participar-shell">
    <div class="container home-container">
      <a href="/" class="back-link">← Voltar aos jogos</a>

      <nav class="participar-steps" aria-label="Etapas da aposta">
        <span class="participar-step is-active">
          <span class="participar-step-num">1</span>
          <span class="participar-step-label">Dados</span>
        </span>
        <span class="participar-step-line" aria-hidden="true"></span>
        <span class="participar-step">
          <span class="participar-step-num">2</span>
          <span class="participar-step-label">Placar</span>
        </span>
        <span class="participar-step-line" aria-hidden="true"></span>
        <span class="participar-step">
          <span class="participar-step-num">3</span>
          <span class="participar-step-label">PIX</span>
        </span>
      </nav>

      <div class="participar-layout">
        <section class="participar-hero" aria-label="Jogo do bolão">
          <div class="participar-hero-head">
            <span class="participar-hero-badge">
              <span class="participar-hero-pulse" aria-hidden="true"></span>
              Bolão aberto
            </span>
          </div>

          <div class="participar-hero-fixture">
            <div class="participar-hero-team-wrap">
              <%- include('partials/team-flag', { name: game.home_team, size: 'md' }) %>
              <span class="participar-hero-team"><%= teamPt(game.home_team) %></span>
            </div>
            <span class="participar-hero-vs" aria-hidden="true">×</span>
            <div class="participar-hero-team-wrap">
              <%- include('partials/team-flag', { name: game.away_team, size: 'md' }) %>
              <span class="participar-hero-team"><%= teamPt(game.away_team) %></span>
            </div>
          </div>

          <time class="participar-hero-date">
            <%= gameDateBR(game.game_date, { weekday: 'short', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
          </time>

          <div class="participar-hero-stats">
            <div class="participar-hero-stat participar-hero-stat--fee">
              <span class="participar-hero-stat-label">Por placar</span>
              <span class="participar-hero-stat-value"><%= formatCents(game.entry_fee_cents) %></span>
            </div>
            <div class="participar-hero-stat participar-hero-stat--prize">
              <span class="participar-hero-stat-label">Prêmio</span>
              <span class="participar-hero-stat-value">🏆 <%= formatCents(game.display_prize_pool_cents != null ? game.display_prize_pool_cents : game.prize_pool_cents) %></span>
            </div>
          </div>

          <% if (Number(game.total_bets) > 0) { %>
            <p class="participar-hero-social">
              <span class="participar-hero-social-dot" aria-hidden="true"></span>
              <%= game.total_bets %> aposta<%= Number(game.total_bets) !== 1 ? 's' : '' %> neste bolão
            </p>
          <% } %>
        </section>

        <%
          let formPhoneCountry = '55';
          let formPhoneLocal = '';
          if (typeof form !== 'undefined' && form) {
            formPhoneCountry = form.phone_country || '55';
            formPhoneLocal = form.phone || '';
          }
          const formPhoneDigits = String(formPhoneLocal).replace(/\D/g, '');
          const showStepDetails = formPhoneDigits.length === 11 && formPhoneDigits[2] === '9';
        %>

        <div class="card participar-card<%= showStepDetails ? '' : ' is-phone-step' %>" id="participar-card">
          <div class="participar-form-progress" aria-label="Progresso do cadastro">
            <span class="participar-form-step is-active" id="form-step-phone">
              <span class="participar-form-step-num">1</span>
              <span class="participar-form-step-text">WhatsApp</span>
            </span>
            <span class="participar-form-step-line" aria-hidden="true"></span>
            <span class="participar-form-step<%= showStepDetails ? ' is-active' : '' %>" id="form-step-data">
              <span class="participar-form-step-num">2</span>
              <span class="participar-form-step-text">Cadastro</span>
            </span>
            <span class="participar-form-step-line" aria-hidden="true"></span>
            <span class="participar-form-step" id="form-step-placar">
              <span class="participar-form-step-num">3</span>
              <span class="participar-form-step-text">Placar</span>
            </span>
          </div>

          <div class="participar-card-head">
            <h2 id="participar-card-title"><%= showStepDetails ? 'Seus dados' : 'Qual é seu WhatsApp?' %></h2>
            <p id="participar-card-desc"><%= showStepDetails
              ? 'Confirme nome e chave PIX para receber o prêmio. O mesmo WhatsApp recebe avisos automáticos.'
              : 'Informe o número com DDD para continuar. É rápido — menos de 1 minuto.' %></p>
          </div>

          <% if (error) { %>
            <div class="alert alert-error" role="alert"><%= error %></div>
          <% } %>

          <form method="POST" action="/games/<%= game.id %>/participar" class="participar-form" id="form-participar">
            <div class="participar-fields">
              <div class="form-group participar-field participar-field-full">
                <label for="phone-country">WhatsApp</label>
                <div class="participar-phone-row">
                  <div class="participar-country-picker" id="phone-country-picker">
                    <input type="hidden" id="phone-country" name="phone_country" value="<%= formPhoneCountry %>">
                    <button type="button" class="participar-country-trigger" id="phone-country-trigger"
                      aria-haspopup="listbox" aria-expanded="false" aria-label="País do WhatsApp">
                      <span class="participar-country-flag"></span>
                      <span class="participar-country-label">+55 Brasil</span>
                      <span class="participar-country-chevron" aria-hidden="true"></span>
                    </button>
                    <ul class="participar-country-menu" id="phone-country-menu" role="listbox" hidden></ul>
                  </div>
                  <div class="participar-input-wrap participar-input-wrap--phone">
                    <span class="participar-input-icon" aria-hidden="true">📱</span>
                    <input type="tel" id="phone" name="phone" class="form-control participar-input" required
                      placeholder="(11) 98114-1234" value="<%= formPhoneLocal %>"
                      inputmode="tel" autocomplete="tel">
                  </div>
                </div>
                <small class="form-hint participar-hint-phone" id="phone-format-hint">
                  Brasil: <strong>(DDD)</strong> + <strong>9</strong> + celular — ex. <strong>(11) 98114-1234</strong>
                </small>
                <small class="form-hint participar-hint-wa" id="phone-wa-hint" hidden>
                  ✓ Formato válido para receber mensagem no WhatsApp
                </small>
                <small class="form-hint participar-hint-error" id="phone-wa-error" hidden>
                  Número incompleto — celular BR precisa de 11 dígitos com o 9 após o DDD
                </small>
                <small class="form-hint participar-hint-found" id="phone-hint" hidden>
                  Cadastro encontrado — confira sua chave PIX abaixo e confirme para continuar.
                </small>
              </div>

              <div class="participar-trust" id="participar-trust"<%= showStepDetails ? ' hidden' : '' %>>
                <span class="participar-trust-item">🔒 PIX seguro</span>
                <span class="participar-trust-item">📲 Aviso de prêmio</span>
                <span class="participar-trust-item">⚡ Menos de 1 min</span>
              </div>

              <div id="participar-step-details" class="participar-step-details<%= showStepDetails ? ' is-visible' : '' %>" aria-hidden="<%= showStepDetails ? 'false' : 'true' %>">
              <div class="participar-section-label">
                <span>Complete seu cadastro</span>
              </div>
              <div class="participar-pix-panel" id="participar-pix-panel" aria-live="polite">
                <span class="participar-pix-label">PIX cadastrada</span>
                <span class="participar-pix-key" id="participar-pix-key"></span>
                <small class="participar-pix-note">Para alterar, fale com o suporte.</small>
              </div>

              <div class="form-group participar-field participar-field-full">
                <label for="name">Nome completo <small>(como no PIX)</small></label>
                <div class="participar-input-wrap">
                  <span class="participar-input-icon" aria-hidden="true">👤</span>
                  <input type="text" id="name" name="name" class="form-control participar-input participar-input--uppercase" required
                    placeholder="SEU NOME COMPLETO" value="<%= typeof form !== 'undefined' && form ? form.name : '' %>"
                    autocomplete="name" autocapitalize="characters">
                </div>
              </div>

              <div class="form-group participar-field participar-field-full" id="cpf-field-group">
                <label for="cpf">Chave PIX <small>(prêmio)</small></label>
                <div class="participar-input-wrap">
                  <span class="participar-input-icon" aria-hidden="true">💰</span>
                  <input type="text" id="cpf" name="cpf" class="form-control participar-input" required
                    placeholder="CPF, telefone ou e-mail"
                    value="<%= typeof form !== 'undefined' && form ? form.cpf : '' %>"
                    autocomplete="off">
                </div>
              </div>

              <div class="form-group participar-field participar-field-full">
                <label for="cpf_confirm">Confirmar chave PIX</label>
                <div class="participar-input-wrap">
                  <span class="participar-input-icon" aria-hidden="true">✓</span>
                  <input type="text" id="cpf_confirm" name="cpf_confirm" class="form-control participar-input" required
                    placeholder="Digite a chave PIX novamente"
                    value="<%= typeof form !== 'undefined' && form ? form.cpf_confirm : '' %>"
                    autocomplete="off">
                </div>
                <small class="form-hint participar-hint-error" id="pix-mismatch-hint" hidden>As chaves PIX não conferem</small>
                <small class="form-hint participar-hint-phone" id="pix-confirm-locked-hint" hidden>
                  Digite a <strong>chave PIX cadastrada</strong> neste WhatsApp para confirmar que é você.
                </small>
              </div>
              </div>
            </div>

            <div id="participar-step-footer" class="participar-step-details<%= showStepDetails ? ' is-visible' : '' %>" aria-hidden="<%= showStepDetails ? 'false' : 'true' %>">
            <label class="participar-check">
              <input type="checkbox" id="accept-rules" required>
              <span>
                Concordo com as <a href="/regras" target="_blank">regras</a>.
                Taxa de <%= systemFeePercent %>% — prêmio: <%= prizeNetPercent %>% aos ganhadores.
              </span>
            </label>

            <button type="submit" class="btn btn-gold btn-block participar-submit" id="btn-submit" disabled>
              <span id="btn-submit-label">Digite seu WhatsApp</span>
              <span class="participar-submit-arrow" aria-hidden="true">→</span>
            </button>
            </div>
          </form>

          <p class="participar-view-only">
            <a href="/games/<%= game.id %>">Só quero ver o bolão →</a>
          </p>


        </div>
      </div>

      <details class="participar-share">
        <summary class="participar-share-summary">
          <span class="participar-share-summary-icon">📣</span>
          <span class="participar-share-summary-text">
            <strong>Convidar amigos</strong>
            <small>Mais gente = prêmio maior</small>
          </span>
          <span class="participar-share-chevron" aria-hidden="true">▼</span>
        </summary>

        <div class="participar-share-body">
          <button type="button" class="btn-share-whatsapp btn-share-compact" id="btn-share-whatsapp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </button>

          <div class="participar-share-actions">
            <button type="button" class="btn-share-secondary btn-share-compact" id="btn-copy-link">
              <span id="btn-copy-label">Copiar link</span>
            </button>
            <a id="btn-telegram" href="#" target="_blank" rel="noopener" class="btn-share-secondary btn-share-compact btn-share-telegram">
              Telegram
            </a>
            <button type="button" class="btn-share-secondary btn-share-compact" id="btn-share-qr">
              QR Code
            </button>
          </div>

          <div class="participar-share-qr-panel" id="share-qr-panel" hidden>
            <div class="participar-share-qr" id="share-qr"></div>
            <p class="participar-share-qr-hint">Escaneie para entrar neste bolão</p>
          </div>

          <input type="text" class="participar-share-url" id="share-link" readonly value="" tabindex="-1" aria-hidden="true" />
        </div>
      </details>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/phone-input.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js"></script>
  <script>
    const gameUrl = window.location.origin + '/games/<%= game.id %>/participar';
    const shareText = '⚽ Bolão: <%= teamPt(game.home_team) %> × <%= teamPt(game.away_team) %>\n💰 <%= formatCents(game.entry_fee_cents) %> por placar\n👉 Entre e aposte:';

    document.getElementById('share-link').value = gameUrl;

    function openWhatsApp() {
      window.open('https://wa.me/?text=' + encodeURIComponent(shareText + '\n' + gameUrl), '_blank');
    }

    document.getElementById('btn-share-whatsapp').onclick = function () {
      if (navigator.share) {
        navigator.share({ title: 'Bolão Online', text: shareText, url: gameUrl }).catch(openWhatsApp);
      } else {
        openWhatsApp();
      }
    };

    document.getElementById('btn-copy-link').onclick = function () {
      navigator.clipboard.writeText(gameUrl).then(() => {
        const label = document.getElementById('btn-copy-label');
        label.textContent = '✓ Copiado!';
        setTimeout(() => { label.textContent = 'Copiar link'; }, 2500);
      });
    };

    document.getElementById('btn-telegram').href =
      'https://t.me/share/url?url=' + encodeURIComponent(gameUrl) + '&text=' + encodeURIComponent(shareText);

    let qrGenerated = false;
    document.getElementById('btn-share-qr').onclick = function () {
      const panel = document.getElementById('share-qr-panel');
      const isHidden = panel.hidden;

      if (!qrGenerated) {
        try {
          const qr = qrcode(0, 'M');
          qr.addData(gameUrl);
          qr.make();
          document.getElementById('share-qr').innerHTML = qr.createSvgTag(3, 8);
          qrGenerated = true;
        } catch (e) {
          console.error('QR error:', e);
        }
      }

      panel.hidden = !isHidden;
      this.textContent = isHidden ? 'Ocultar QR' : 'QR Code';
    };

    function normalizePixKey(val) {
      const trimmed = (val || '').trim();
      if (!trimmed) return '';
      const digitsOnly = trimmed.replace(/\D/g, '');
      const stripped = trimmed.replace(/[\s.\-/()]/g, '');
      if (stripped === digitsOnly && digitsOnly.length >= 5) return digitsOnly;
      return trimmed.toLowerCase();
    }

    function pixKeysMatch(a, b) {
      const left = normalizePixKey(a);
      const right = normalizePixKey(b);
      return left.length > 0 && left === right;
    }

    const cpfInput = document.getElementById('cpf');
    const cpfConfirmInput = document.getElementById('cpf_confirm');
    const pixMismatchHint = document.getElementById('pix-mismatch-hint');
    const pixConfirmLockedHint = document.getElementById('pix-confirm-locked-hint');
    const participarPixPanel = document.getElementById('participar-pix-panel');
    const participarPixKey = document.getElementById('participar-pix-key');
    const cpfFieldGroup = document.getElementById('cpf-field-group');
    const participarStepDetails = document.getElementById('participar-step-details');
    const participarStepFooter = document.getElementById('participar-step-footer');
    const participarCard = document.getElementById('participar-card');
    const participarCardTitle = document.getElementById('participar-card-title');
    const participarCardDesc = document.getElementById('participar-card-desc');
    const participarTrust = document.getElementById('participar-trust');
    const formStepPhone = document.getElementById('form-step-phone');
    const formStepData = document.getElementById('form-step-data');
    const btnSubmitLabel = document.getElementById('btn-submit-label');
    const acceptRules = document.getElementById('accept-rules');
    const btnSubmit = document.getElementById('btn-submit');
    const participarForm = document.getElementById('form-participar');
    const phoneHint = document.getElementById('phone-hint');
    const phoneWaHint = document.getElementById('phone-wa-hint');
    const phoneWaError = document.getElementById('phone-wa-error');
    const phoneFormatHint = document.getElementById('phone-format-hint');
    const nameInput = document.getElementById('name');

    let phoneWidget = null;
    let lookupTimeout;
    let existingUserLocked = false;

    function updatePixMatchState() {
      const confirm = cpfConfirmInput.value.trim();
      if (existingUserLocked) {
        cpfInput.classList.remove('participar-input--error');
        cpfConfirmInput.classList.remove('participar-input--error');
        pixMismatchHint.hidden = true;
        return confirm.length >= 5;
      }

      const pix = cpfInput.value;
      const bothFilled = pix.trim() && confirm;
      const mismatch = bothFilled && !pixKeysMatch(pix, confirm);

      cpfInput.classList.toggle('participar-input--error', mismatch);
      cpfConfirmInput.classList.toggle('participar-input--error', mismatch);
      pixMismatchHint.hidden = !mismatch;

      return !mismatch;
    }

    function updateSubmitState() {
      if (!isPhoneReady()) {
        btnSubmit.disabled = true;
        btnSubmitLabel.textContent = 'Digite seu WhatsApp';
        return;
      }
      const pixOk = updatePixMatchState();
      const confirmFilled = cpfConfirmInput.value.trim().length >= (existingUserLocked ? 5 : 1);
      const cpfFieldOk = existingUserLocked || cpfInput.value.trim().length > 0;
      const nameOk = nameInput.value.trim().length >= 3;
      const allReady = acceptRules.checked && pixOk && confirmFilled && cpfFieldOk && nameOk;
      btnSubmit.disabled = !allReady;
      btnSubmitLabel.textContent = allReady ? 'Continuar para o placar' : 'Continuar';
    }

    cpfInput.addEventListener('input', updateSubmitState);
    cpfConfirmInput.addEventListener('input', updateSubmitState);
    nameInput.addEventListener('input', updateSubmitState);

    participarForm.addEventListener('submit', function (e) {
      normalizeNameInput();
      if (!isPhoneReady()) {
        e.preventDefault();
        phoneWaError.hidden = false;
        document.getElementById('phone').focus();
        return;
      }
      if (existingUserLocked) {
        if (cpfConfirmInput.value.trim().length < 5) {
          e.preventDefault();
          cpfConfirmInput.focus();
        }
        return;
      }
      if (!pixKeysMatch(cpfInput.value, cpfConfirmInput.value)) {
        e.preventDefault();
        updatePixMatchState();
        cpfConfirmInput.focus();
      }
    });

    function setPixPanelVisible(show, pixKey) {
      const key = (pixKey || '').trim();
      if (show && key.length >= 5) {
        participarPixKey.textContent = key;
        participarPixPanel.classList.add('is-visible');
      } else {
        participarPixKey.textContent = '';
        participarPixPanel.classList.remove('is-visible');
      }
    }

    function setExistingUserLocked(locked, data) {
      if (existingUserLocked && !locked) {
        nameInput.value = '';
        cpfInput.value = '';
        cpfConfirmInput.value = '';
        cpfInput.disabled = false;
        cpfInput.setAttribute('name', 'cpf');
        cpfInput.setAttribute('required', '');
        cpfConfirmInput.placeholder = 'Digite a chave PIX novamente';
        setPixPanelVisible(false);
        cpfFieldGroup.hidden = false;
      }
      existingUserLocked = locked;
      nameInput.readOnly = locked;
      cpfInput.readOnly = locked;
      cpfConfirmInput.readOnly = false;
      nameInput.classList.toggle('participar-input--readonly', locked);
      cpfInput.classList.toggle('participar-input--readonly', locked);
      cpfConfirmInput.classList.toggle('participar-input--readonly', false);
      pixConfirmLockedHint.hidden = !locked;
      cpfFieldGroup.hidden = locked;

      if (locked && data) {
        nameInput.value = (data.name || '').toUpperCase();
        const pixKey = data.pix_key || data.pix_masked || '';
        setPixPanelVisible(true, pixKey);
        cpfInput.value = '';
        cpfInput.disabled = true;
        cpfInput.removeAttribute('name');
        cpfInput.removeAttribute('required');
        cpfConfirmInput.value = '';
        cpfConfirmInput.placeholder = 'Digite sua chave PIX cadastrada';
        if (pixKey.trim().length >= 5) {
          setTimeout(() => cpfConfirmInput.focus(), 100);
        }
      } else if (!locked) {
        setPixPanelVisible(false);
        cpfInput.removeAttribute('aria-label');
      }
    }

    function normalizeNameInput() {
      if (!existingUserLocked) {
        nameInput.value = nameInput.value.toUpperCase();
      }
    }

    function isPhoneReady() {
      if (!phoneWidget) return false;
      const dial = phoneWidget.getCountryDial();
      const digits = phoneWidget.getLocalDigits();
      if (dial === '55') return digits.length === 11 && digits[2] === '9';
      return digits.length >= 8;
    }

    function setStepDetailsVisible(show) {
      participarStepDetails.classList.toggle('is-visible', show);
      participarStepFooter.classList.toggle('is-visible', show);
      participarStepDetails.setAttribute('aria-hidden', show ? 'false' : 'true');
      participarStepFooter.setAttribute('aria-hidden', show ? 'false' : 'true');
      participarCard.classList.toggle('is-phone-step', !show);
      if (participarTrust) participarTrust.hidden = show;
      formStepData.classList.toggle('is-active', show);
      formStepPhone.classList.toggle('is-done', show);
      if (participarCardTitle) {
        participarCardTitle.textContent = show ? 'Seus dados' : 'Qual é seu WhatsApp?';
      }
      if (participarCardDesc) {
        participarCardDesc.textContent = show
          ? 'Confirme nome e chave PIX para receber o prêmio. O mesmo WhatsApp recebe avisos automáticos.'
          : 'Informe o número com DDD para continuar. É rápido — menos de 1 minuto.';
      }
    }

    function updatePhoneStep() {
      const ready = isPhoneReady();
      const wasHidden = !participarStepDetails.classList.contains('is-visible');
      setStepDetailsVisible(ready);
      if (!ready) {
        phoneHint.hidden = true;
        setExistingUserLocked(false);
        setPixPanelVisible(false);
      } else if (wasHidden && !existingUserLocked) {
        setTimeout(() => {
          participarStepDetails.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          nameInput.focus();
        }, 120);
      }
      updateSubmitState();
    }

    function scheduleLookup(digits, countryDial) {
      clearTimeout(lookupTimeout);
      const minDigits = countryDial === '55' ? 10 : 8;
      if (digits.length < minDigits) {
        phoneHint.hidden = true;
        setExistingUserLocked(false);
        setPixPanelVisible(false);
        return;
      }

      lookupTimeout = setTimeout(() => {
        fetch('/api/lookup-phone', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone: digits, phone_country: countryDial })
        })
          .then(r => r.json())
          .then(data => {
            if (data.found && data.locked) {
              setExistingUserLocked(true, data);
              phoneHint.hidden = false;
              updateSubmitState();
            } else {
              setExistingUserLocked(false);
              phoneHint.hidden = true;
              updateSubmitState();
            }
          })
          .catch(() => {
            setExistingUserLocked(false);
            phoneHint.hidden = true;
          });
      }, 450);
    }

    function onPhoneDigitsChange(digits, countryDial) {
      if (countryDial === '55') {
        phoneFormatHint.innerHTML = 'Brasil: <strong>(DDD)</strong> + <strong>9</strong> + celular — ex. <strong>(11) 98114-1234</strong>';
        const ok = digits.length === 11 && digits[2] === '9';
        phoneWaHint.hidden = !ok;
        phoneWaError.hidden = ok || digits.length < 8;
      } else {
        phoneFormatHint.textContent = 'Digite o número com DDD/área local, sem o código do país.';
        phoneWaHint.hidden = digits.length < 8;
        phoneWaError.hidden = digits.length >= 8;
      }
      updatePhoneStep();
      scheduleLookup(digits, countryDial);
    }

    setPixPanelVisible(false);
    if (!<%= showStepDetails ? 'true' : 'false' %>) {
      setStepDetailsVisible(false);
    } else {
      setStepDetailsVisible(true);
    }

    phoneWidget = PhoneInput.init({
      countryPicker: '#phone-country-picker',
      phoneInput: '#phone',
      defaultCountry: '55',
      initialCountry: '55',
      initialLocal: '<%= formPhoneLocal.replace(/'/g, "\\'") %>',
      onDigitsChange: onPhoneDigitsChange,
    });

    updatePhoneStep();

    nameInput.addEventListener('input', normalizeNameInput);
    nameInput.addEventListener('blur', normalizeNameInput);
    normalizeNameInput();

    acceptRules.addEventListener('change', updateSubmitState);
    updateSubmitState();

    if (participarCard.classList.contains('is-phone-step')) {
      const phoneEl = document.getElementById('phone');
      if (phoneEl && !phoneEl.value.trim()) {
        setTimeout(() => phoneEl.focus(), 200);
      }
    }
  </script>
</body>
</html>
