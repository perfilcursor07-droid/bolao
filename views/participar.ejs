<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= teamPt(game.home_team) %> × <%= teamPt(game.away_team) %> | Bolão</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-participar">
  <%- include('partials/header') %>

  <main class="participar-shell">
    <div class="participar-page">
      <a href="/" class="back-link">← Voltar aos jogos</a>

      <nav class="participar-steps" aria-label="Etapas da aposta">
        <span class="participar-step is-active">
          <span class="participar-step-num">1</span>
          <span class="participar-step-label">Dados</span>
        </span>
        <span class="participar-step-line" aria-hidden="true"></span>
        <span class="participar-step">
          <span class="participar-step-num">2</span>
          <span class="participar-step-label">Placar</span>
        </span>
        <span class="participar-step-line" aria-hidden="true"></span>
        <span class="participar-step">
          <span class="participar-step-num">3</span>
          <span class="participar-step-label">PIX</span>
        </span>
      </nav>

      <div class="participar-layout">
        <section class="participar-hero" aria-label="Jogo do bolão">
          <div class="participar-hero-head">
            <span class="participar-hero-badge">
              <span class="participar-hero-pulse" aria-hidden="true"></span>
              Bolão aberto
            </span>
          </div>

          <div class="participar-hero-fixture">
            <div class="participar-hero-team-wrap">
              <span class="participar-hero-team"><%= teamPt(game.home_team) %></span>
            </div>
            <span class="participar-hero-vs" aria-hidden="true">×</span>
            <div class="participar-hero-team-wrap">
              <span class="participar-hero-team"><%= teamPt(game.away_team) %></span>
            </div>
          </div>

          <time class="participar-hero-date">
            <%= gameDateBR(game.game_date, { weekday: 'short', day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
          </time>

          <div class="participar-hero-stats">
            <div class="participar-hero-stat participar-hero-stat--fee">
              <span class="participar-hero-stat-label">Por placar</span>
              <span class="participar-hero-stat-value"><%= formatCents(game.entry_fee_cents) %></span>
            </div>
            <div class="participar-hero-stat participar-hero-stat--prize">
              <span class="participar-hero-stat-label">Prêmio</span>
              <span class="participar-hero-stat-value">🏆 <%= formatCents(game.prize_pool_cents) %></span>
            </div>
          </div>
        </section>

        <div class="card participar-card">
          <div class="participar-card-head">
            <h2>Identifique-se</h2>
            <p>Rápido — em seguida você escolhe o placar. Depois do jogo, <a href="/consultar">consulte pelo WhatsApp</a> se ganhou.</p>
          </div>

          <% if (error) { %>
            <div class="alert alert-error" role="alert"><%= error %></div>
          <% } %>

          <form method="POST" action="/games/<%= game.id %>/participar" class="participar-form" id="form-participar">
            <div class="participar-fields">
              <div class="form-group participar-field participar-field-full">
                <label for="phone">WhatsApp</label>
                <div class="participar-input-wrap">
                  <span class="participar-input-icon" aria-hidden="true">📱</span>
                  <input type="tel" id="phone" name="phone" class="form-control participar-input" required
                    placeholder="(00) 00000-0000" value="<%= typeof form !== 'undefined' && form ? form.phone : '' %>"
                    autocomplete="tel">
                </div>
                <small class="form-hint participar-hint-found" id="phone-hint" hidden>✓ Cadastro encontrado — dados preenchidos</small>
              </div>

              <div class="form-group participar-field">
                <label for="name">Nome</label>
                <div class="participar-input-wrap">
                  <span class="participar-input-icon" aria-hidden="true">👤</span>
                  <input type="text" id="name" name="name" class="form-control participar-input" required
                    placeholder="Seu nome" value="<%= typeof form !== 'undefined' && form ? form.name : '' %>"
                    autocomplete="name">
                </div>
              </div>

              <div class="form-group participar-field">
                <label for="cpf">Chave PIX <small>(prêmio)</small></label>
                <div class="participar-input-wrap">
                  <span class="participar-input-icon" aria-hidden="true">💰</span>
                  <input type="text" id="cpf" name="cpf" class="form-control participar-input" required
                    placeholder="CPF, telefone ou e-mail"
                    value="<%= typeof form !== 'undefined' && form ? form.cpf : '' %>"
                    autocomplete="off">
                </div>
              </div>
            </div>

            <label class="participar-check">
              <input type="checkbox" id="accept-rules" required>
              <span>
                Concordo com as <a href="/regras" target="_blank">regras</a>.
                Taxa de <%= systemFeePercent %>% — prêmio: <%= prizeNetPercent %>% aos ganhadores.
              </span>
            </label>

            <button type="submit" class="btn btn-gold btn-block participar-submit" id="btn-submit" disabled>
              Continuar
              <span class="participar-submit-arrow" aria-hidden="true">→</span>
            </button>
          </form>


        </div>
      </div>

      <details class="participar-share">
        <summary class="participar-share-summary">
          <span class="participar-share-summary-icon">📣</span>
          <span class="participar-share-summary-text">
            <strong>Convidar amigos</strong>
            <small>Mais gente = prêmio maior</small>
          </span>
          <span class="participar-share-chevron" aria-hidden="true">▼</span>
        </summary>

        <div class="participar-share-body">
          <button type="button" class="btn-share-whatsapp btn-share-compact" id="btn-share-whatsapp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </button>

          <div class="participar-share-actions">
            <button type="button" class="btn-share-secondary btn-share-compact" id="btn-copy-link">
              <span id="btn-copy-label">Copiar link</span>
            </button>
            <a id="btn-telegram" href="#" target="_blank" rel="noopener" class="btn-share-secondary btn-share-compact btn-share-telegram">
              Telegram
            </a>
            <button type="button" class="btn-share-secondary btn-share-compact" id="btn-share-qr">
              QR Code
            </button>
          </div>

          <div class="participar-share-qr-panel" id="share-qr-panel" hidden>
            <div class="participar-share-qr" id="share-qr"></div>
            <p class="participar-share-qr-hint">Escaneie para entrar neste bolão</p>
          </div>

          <input type="text" class="participar-share-url" id="share-link" readonly value="" tabindex="-1" aria-hidden="true" />
        </div>
      </details>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js"></script>
  <script>
    const gameUrl = window.location.origin + '/games/<%= game.id %>/participar';
    const shareText = '⚽ Bolão: <%= teamPt(game.home_team) %> × <%= teamPt(game.away_team) %>\n💰 <%= formatCents(game.entry_fee_cents) %> por placar\n👉 Entre e aposte:';

    document.getElementById('share-link').value = gameUrl;

    function openWhatsApp() {
      window.open('https://wa.me/?text=' + encodeURIComponent(shareText + '\n' + gameUrl), '_blank');
    }

    document.getElementById('btn-share-whatsapp').onclick = function () {
      if (navigator.share) {
        navigator.share({ title: 'Bolão Online', text: shareText, url: gameUrl }).catch(openWhatsApp);
      } else {
        openWhatsApp();
      }
    };

    document.getElementById('btn-copy-link').onclick = function () {
      navigator.clipboard.writeText(gameUrl).then(() => {
        const label = document.getElementById('btn-copy-label');
        label.textContent = '✓ Copiado!';
        setTimeout(() => { label.textContent = 'Copiar link'; }, 2500);
      });
    };

    document.getElementById('btn-telegram').href =
      'https://t.me/share/url?url=' + encodeURIComponent(gameUrl) + '&text=' + encodeURIComponent(shareText);

    let qrGenerated = false;
    document.getElementById('btn-share-qr').onclick = function () {
      const panel = document.getElementById('share-qr-panel');
      const isHidden = panel.hidden;

      if (!qrGenerated) {
        try {
          const qr = qrcode(0, 'M');
          qr.addData(gameUrl);
          qr.make();
          document.getElementById('share-qr').innerHTML = qr.createSvgTag(3, 8);
          qrGenerated = true;
        } catch (e) {
          console.error('QR error:', e);
        }
      }

      panel.hidden = !isHidden;
      this.textContent = isHidden ? 'Ocultar QR' : 'QR Code';
    };

    const phoneInput = document.getElementById('phone');
    const phoneHint = document.getElementById('phone-hint');

    phoneInput.addEventListener('input', function (e) {
      let v = e.target.value.replace(/\D/g, '');
      if (v.length > 11) v = v.slice(0, 11);
      if (v.length > 10) v = v.replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3');
      else if (v.length > 6) v = v.replace(/(\d{2})(\d{4,5})(\d{0,4})/, '($1) $2-$3');
      else if (v.length > 2) v = v.replace(/(\d{2})(\d{0,5})/, '($1) $2');
      e.target.value = v;
    });

    let lookupTimeout;
    phoneInput.addEventListener('input', function () {
      clearTimeout(lookupTimeout);
      const digits = this.value.replace(/\D/g, '');
      if (digits.length >= 10) {
        lookupTimeout = setTimeout(() => {
          fetch('/api/lookup-phone', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone: digits })
          })
            .then(r => r.json())
            .then(data => {
              if (data.found) {
                const nameEl = document.getElementById('name');
                const cpfEl = document.getElementById('cpf');
                if (!nameEl.value) nameEl.value = data.name;
                if (!cpfEl.value && data.cpf) cpfEl.value = data.cpf;
                phoneHint.hidden = false;
              } else {
                phoneHint.hidden = true;
              }
            })
            .catch(() => {});
        }, 500);
      } else {
        phoneHint.hidden = true;
      }
    });

    document.getElementById('accept-rules').addEventListener('change', function () {
      document.getElementById('btn-submit').disabled = !this.checked;
    });
  </script>
</body>
</html>
