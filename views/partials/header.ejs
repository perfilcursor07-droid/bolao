<nav class="navbar">
  <a href="/" class="navbar-brand">
    <%- include('logo') %>
    <span class="brand-text">Bolão <span class="brand-accent">Online</span></span>
  </a>

  <div class="navbar-center" id="navbar-nav">
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/" class="nav-pill">Jogos</a>
      <a href="/boloes-encerrados" class="nav-pill">Encerrados</a>
      <a href="/ganhadores" class="nav-pill">Ganhadores</a>
      <a href="/my-bets" class="nav-pill">Apostas</a>
      <a href="/regras" class="nav-pill">Regras</a>
      <a href="/afiliado" class="nav-pill">Afiliados</a>
      <% if (user.role === 'admin') { %>
        <a href="/admin" class="nav-pill nav-pill-admin">Admin</a>
      <% } %>
    <% } else { %>
      <a href="/boloes-encerrados" class="nav-pill">Encerrados</a>
      <a href="/ganhadores" class="nav-pill">Ganhadores</a>
      <a href="/consultar" class="nav-pill">Consultar</a>
      <a href="/regras" class="nav-pill">Regras</a>
      <a href="/afiliado" class="nav-pill">Afiliados</a>
    <% } %>
  </div>

  <% if (typeof user !== 'undefined' && user) { %>
    <div class="navbar-tools navbar-tools--bar">
      <%- include('nav-tools') %>
    </div>
  <% } %>

  <div class="navbar-actions">
    <% if (typeof user !== 'undefined' && user) { %>
      <div class="navbar-tools navbar-tools--desktop">
        <%- include('nav-tools') %>
      </div>
      <div class="nav-user" title="<%= user.name %>">
        <a href="/painel" class="nav-user-link">
          <span class="nav-avatar"><%= user.name.charAt(0).toUpperCase() %></span>
          <span class="nav-user-name"><%= user.name.split(' ')[0] %></span>
        </a>
      </div>
      <a href="/logout" class="nav-link-quiet">Sair</a>
    <% } else { %>
      <a href="/login" class="nav-link-quiet">Entrar</a>
      <a href="/register" class="nav-btn-cta">Cadastrar</a>
    <% } %>
  </div>

  <button class="nav-toggle" id="nav-toggle" aria-label="Menu" type="button" aria-expanded="false">
    <span></span><span></span>
  </button>
</nav>

<div class="nav-mobile" id="nav-mobile" aria-hidden="true">
  <% if (typeof user !== 'undefined' && user) { %>
    <div class="nav-mobile-user">
      <a href="/painel" class="nav-mobile-user-link">
        <span class="nav-avatar"><%= user.name.charAt(0).toUpperCase() %></span>
        <div>
          <strong><%= user.name.split(' ')[0] %></strong>
          <small>Minha conta</small>
        </div>
      </a>
    </div>
    <nav class="nav-mobile-links">
      <a href="/painel" class="nav-mobile-link"><span class="nav-mobile-link-label">Minha conta</span></a>
      <a href="/" class="nav-mobile-link"><span class="nav-mobile-link-label">Jogos</span></a>
      <a href="/boloes-encerrados" class="nav-mobile-link"><span class="nav-mobile-link-label">Encerrados</span></a>
      <a href="/ganhadores" class="nav-mobile-link"><span class="nav-mobile-link-label">Ganhadores</span></a>
      <a href="/carrinho" class="nav-mobile-link">
        <span class="nav-mobile-link-label">Carrinho</span>
        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
          <span class="nav-mobile-badge"><%= cartCount %></span>
        <% } %>
      </a>
      <a href="/my-bets" class="nav-mobile-link"><span class="nav-mobile-link-label">Apostas</span></a>
      <a href="/my-payments" class="nav-mobile-link">
        <span class="nav-mobile-link-label">Pagamentos</span>
        <% if (typeof pendingPaymentsCount !== 'undefined' && pendingPaymentsCount > 0) { %>
          <span class="nav-mobile-badge nav-mobile-badge--warn"><%= pendingPaymentsCount %></span>
        <% } %>
      </a>
      <a href="/regras" class="nav-mobile-link"><span class="nav-mobile-link-label">Regras</span></a>
      <a href="/afiliado" class="nav-mobile-link"><span class="nav-mobile-link-label">Afiliados</span></a>
      <% if (user.role === 'admin') { %>
        <a href="/admin" class="nav-mobile-link"><span class="nav-mobile-link-label">Admin</span></a>
      <% } %>
    </nav>
    <div class="nav-mobile-footer">
      <a href="/logout" class="nav-mobile-link nav-mobile-link--exit">Sair da conta</a>
    </div>
  <% } else { %>
    <nav class="nav-mobile-links">
      <a href="/boloes-encerrados" class="nav-mobile-link"><span class="nav-mobile-link-label">Encerrados</span></a>
      <a href="/ganhadores" class="nav-mobile-link"><span class="nav-mobile-link-label">Ganhadores</span></a>
      <a href="/consultar" class="nav-mobile-link"><span class="nav-mobile-link-label">Consultar apostas</span></a>
      <a href="/regras" class="nav-mobile-link"><span class="nav-mobile-link-label">Regras</span></a>
    </nav>
    <div class="nav-mobile-guest">
      <p class="nav-mobile-guest-title">Bem-vindo</p>
      <p class="nav-mobile-guest-text">Entre ou cadastre-se para participar dos bolões.</p>
    </div>
    <div class="nav-mobile-footer nav-mobile-footer-guest">
      <a href="/login" class="nav-btn-cta nav-btn-cta--block">Entrar</a>
      <a href="/register" class="nav-link-quiet nav-link-quiet--block">Criar conta</a>
    </div>
  <% } %>
</div>

<script>
  (function () {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('nav-mobile');
    if (!toggle || !menu) return;

    function setOpen(open) {
      menu.classList.toggle('open', open);
      toggle.classList.toggle('open', open);
      document.body.classList.toggle('nav-open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      menu.setAttribute('aria-hidden', open ? 'false' : 'true');
    }

    toggle.addEventListener('click', () => setOpen(!menu.classList.contains('open')));

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
  })();
</script>
