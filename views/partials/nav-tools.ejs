<%
  const cartItems = typeof cartCount !== 'undefined' ? Number(cartCount) : 0;
  const pendingPix = typeof pendingPaymentsCount !== 'undefined' ? Number(pendingPaymentsCount) : 0;
  const cartBadgeTotal = cartItems + pendingPix;
%>
<a href="/carrinho" class="nav-cart-btn" title="Carrinho e apostas aguardando pagamento" aria-label="Carrinho<%= cartBadgeTotal > 0 ? `, ${cartBadgeTotal} pendente${cartBadgeTotal !== 1 ? 's' : ''}` : '' %>">
  <svg class="nav-cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="9" cy="21" r="1"/>
    <circle cx="20" cy="21" r="1"/>
    <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
  </svg>
  <span class="nav-cart-label">Carrinho</span>
  <% if (cartBadgeTotal > 0) { %>
    <span class="nav-cart-badge<%= pendingPix > 0 && cartItems === 0 ? ' nav-cart-badge--warn' : '' %>"><%= cartBadgeTotal %></span>
  <% } %>
</a>
