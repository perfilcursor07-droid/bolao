<% if (typeof finishedSummaries !== 'undefined' && finishedSummaries.length > 0) { %>
  <% var modalMode = typeof useWinnerModal !== 'undefined' && useWinnerModal; %>
  <% var showAllBetsList = typeof showAllBets !== 'undefined' && showAllBets; %>
  <div class="finished-boloes-list<%= modalMode ? ' finished-boloes-list--modal' : '' %>">
    <% finishedSummaries.forEach(function(item) { %>
      <% var game = item.game, winners = item.winners, breakdown = item.breakdown, bets = item.bets || []; %>
      <% var hasWinners = winners.length > 0; %>
      <% var badgeLabel = hasWinners
        ? winners.length + ' ganhador' + (winners.length > 1 ? 'es' : '')
        : 'Sem ganhadores'; %>
      <% var matchLabel = teamPt(game.home_team) + ' × ' + teamPt(game.away_team); %>

      <% if (modalMode) { %>
        <article
          class="finished-bolao finished-bolao-twin<%= hasWinners ? ' finished-bolao-twin--won' : '' %>"
          data-game-id="<%= game.id %>"
        >
          <div class="finished-bolao-twin-inner">
            <header class="finished-bolao-twin-head">
              <span class="finished-bolao-twin-kicker">Encerrado</span>
              <% if (game.game_date) { %>
                <time class="finished-bolao-twin-date"><%= gameDateBR(game.game_date) %></time>
              <% } %>
            </header>

            <% if (game.title) { %>
              <p class="finished-bolao-twin-title"><%= game.title %></p>
            <% } %>

            <div class="finished-bolao-twin-match">
              <span class="finished-bolao-twin-team">
                <%- include('team-flag', { name: game.home_team, size: 'md' }) %>
                <%= teamPt(game.home_team) %>
              </span>
              <span class="finished-bolao-twin-score"><%= game.home_score %> × <%= game.away_score %></span>
              <span class="finished-bolao-twin-team">
                <%- include('team-flag', { name: game.away_team, size: 'md' }) %>
                <%= teamPt(game.away_team) %>
              </span>
            </div>

            <div class="finished-bolao-winners-row">
              <button
                type="button"
                class="finished-winners-twin-btn finished-winners-btn<%= hasWinners ? '' : ' finished-winners-twin-btn--empty' %>"
                data-game-id="<%= game.id %>"
                data-match="<%= matchLabel %>"
                data-title="<%= game.title || matchLabel %>"
                aria-haspopup="dialog"
              >
                <span class="finished-winners-twin-icon" aria-hidden="true"><%= hasWinners ? '🏆' : '—' %></span>
                <span class="finished-winners-twin-label"><%= badgeLabel %></span>
              </button>
              <% if (hasWinners && breakdown.prizeEach > 0) { %>
                <p class="finished-winner-prize-hint"><%= formatCents(breakdown.prizeEach) %> <span>por ganhador</span></p>
              <% } %>
            </div>

            <div class="finished-bolao-twin-stats">
              <span class="finished-bolao-twin-stat">
                <small>Arrecadado</small>
                <strong><%= formatCents(breakdown.totalPool) %></strong>
              </span>
              <span class="finished-bolao-twin-stat">
                <small>Apostas</small>
                <strong><%= game.total_bets %></strong>
              </span>
            </div>
          </div>
          <template id="finished-bolao-data-<%= game.id %>">
            <%- include('finished-bolao-detail', { game, winners, breakdown, bets, showAllBets: showAllBetsList }) %>
          </template>
        </article>
      <% } else { %>
        <details class="finished-bolao" data-game-id="<%= game.id %>">
          <summary class="finished-bolao-summary">
            <div class="finished-bolao-teams">
              <span class="finished-team">
                <%- include('team-flag', { name: game.home_team, size: 'sm' }) %>
                <%= teamPt(game.home_team) %>
              </span>
              <span class="finished-score"><%= game.home_score %> × <%= game.away_score %></span>
              <span class="finished-team">
                <%- include('team-flag', { name: game.away_team, size: 'sm' }) %>
                <%= teamPt(game.away_team) %>
              </span>
            </div>
            <div class="finished-bolao-meta">
              <span class="finished-pool"><%= formatCents(breakdown.totalPool) %></span>
              <span class="finished-bets-count"><%= game.total_bets %> aposta<%= game.total_bets !== 1 ? 's' : '' %></span>
              <% if (hasWinners) { %>
                <span class="finished-winners-badge"><%= badgeLabel %></span>
              <% } else { %>
                <span class="finished-winners-badge finished-winners-badge--empty"><%= badgeLabel %></span>
              <% } %>
            </div>
          </summary>
          <div class="finished-bolao-body">
            <%- include('finished-bolao-detail', { game, winners, breakdown, bets, showAllBets: showAllBetsList }) %>
          </div>
        </details>
      <% } %>
    <% }); %>
  </div>
<% } %>
