<% if (typeof breakdown !== 'undefined' && breakdown) { %>
  <div class="prize-breakdown<%= typeof compact !== 'undefined' && compact ? ' prize-breakdown--compact' : '' %>">
    <div class="prize-breakdown-row">
      <span>Total arrecadado</span>
      <strong><%= formatCents(breakdown.totalPool) %></strong>
    </div>
    <div class="prize-breakdown-row prize-breakdown-fee">
      <span>Taxa da plataforma (<%= breakdown.feePercent %>%)</span>
      <strong>− <%= formatCents(breakdown.feeCents) %></strong>
    </div>
    <div class="prize-breakdown-row prize-breakdown-net">
      <span>Prêmio líquido (<%= breakdown.netPercent %>% aos ganhadores)</span>
      <strong><%= formatCents(breakdown.netPool) %></strong>
    </div>
  </div>
<% } %>

<% if (typeof bets !== 'undefined' && bets && bets.length > 0) { %>
  <% if (typeof betsTitle !== 'undefined' && betsTitle) { %>
    <h4 class="closed-betting-bets-title"><%= betsTitle %> (<%= bets.length %>)</h4>
  <% } %>
  <div class="closed-bets-list<%= typeof compact !== 'undefined' && compact ? ' closed-bets-list--compact' : '' %><%= typeof listClass !== 'undefined' && listClass ? ' ' + listClass : '' %>">
    <% bets.forEach(function(bet) { %>
      <%- include('bet-public-row', { bet, rowClass: 'closed-bet-row' }) %>
    <% }); %>
  </div>
<% } else if (typeof showEmpty !== 'undefined' && showEmpty) { %>
  <p class="closed-betting-empty">Nenhuma aposta neste bolão ainda.</p>
<% } %>
