<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | Bolão Online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-payment">
  <%- include('partials/header') %>

  <div class="container payment-page">
    <div class="payment-steps">
      <div class="payment-step done">
        <span class="payment-step-icon">✓</span>
        <span>Placares</span>
      </div>
      <div class="payment-step-line done"></div>
      <div class="payment-step active">
        <span class="payment-step-icon">2</span>
        <span>PIX</span>
      </div>
    </div>

    <div class="card payment-card">
      <div class="payment-top">
        <span class="pix-badge">PIX</span>
        <h1>Pague para confirmar</h1>
        <p class="payment-match">
          <%= teamPt(payment.home_team) %>
          <span>×</span>
          <%= teamPt(payment.away_team) %>
        </p>
      </div>

      <% const predRaw = payment.prediction_data ? (typeof payment.prediction_data === 'string' ? JSON.parse(payment.prediction_data) : payment.prediction_data) : null; %>
      <% const placares = predRaw && predRaw.placares ? predRaw.placares : (predRaw && predRaw.home !== undefined ? [predRaw] : []); %>

      <div class="payment-summary">
        <% if (placares.length > 0) { %>
          <div class="payment-summary-picks">
            <span class="payment-summary-label">
              <%= placares.length === 1 ? 'Seu palpite' : placares.length + ' placares' %>
            </span>
            <div class="placar-chips">
              <% placares.forEach(function(p) { %>
                <span class="placar-chip"><%= p.home %> × <%= p.away %></span>
              <% }); %>
            </div>
          </div>
        <% } %>
        <div class="payment-summary-amount">
          <span class="payment-summary-label">
            <%= placares.length > 1 ? 'Total' : 'Valor' %>
          </span>
          <strong><%= formatCents(payment.amount_cents) %></strong>
        </div>
      </div>

      <% if (typeof paymentClosed !== 'undefined' && paymentClosed) { %>
        <div class="alert alert-error payment-error-box">
          <strong>PIX expirado — apostas encerradas</strong>
          <p style="margin:0.5rem 0 0; font-size:0.88rem; line-height:1.45;">
            O prazo para pagar este bolão já passou (apostas fecham <%= bettingCloseMinutes %> minutos antes do jogo).
            Este QR Code <strong>não pode mais ser usado</strong> e nenhuma aposta será registrada.
          </p>
          <a href="/" class="btn btn-outline btn-block" style="margin-top:0.85rem;">Ver jogos abertos</a>
        </div>
      <% } else if (!qrImage && !payment.qr_code_text) { %>
        <div class="alert alert-error payment-error-box">
          Não foi possível gerar o QR Code PIX. Volte e tente novamente.
          <a href="/games/<%= payment.game_id %>/placar?error=payment" class="btn btn-outline btn-block" style="margin-top:0.75rem;">
            Tentar novamente
          </a>
        </div>
      <% } else { %>
        <div class="payment-qr-block">
          <div id="status-badge" class="payment-status payment-pending">
            <span class="pulse"></span> Aguardando pagamento
          </div>

          <% if (qrImage) { %>
            <div class="qr-code-wrap">
              <div class="qr-code">
                <img src="<%= qrImage %>" alt="QR Code PIX">
              </div>
            </div>
            <p class="qr-hint">Escaneie com o app do seu banco</p>
          <% } %>

          <% if (payment.qr_code_text) { %>
            <button type="button" class="btn btn-gold btn-block btn-copy-pix" id="btn-copy" onclick="copyPix()">
              Copiar código PIX
            </button>
            <input type="hidden" id="pix-code" value="<%= payment.qr_code_text %>">
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    function copyPix() {
      const text = document.getElementById('pix-code').value;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('btn-copy');
        btn.textContent = 'Código copiado!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'Copiar código PIX';
          btn.classList.remove('copied');
        }, 3000);
      });
    }

    function checkStatus() {
      fetch('/payment/<%= payment.id %>/status')
        .then(r => r.json())
        .then(data => {
          if (data.status === 'paid') {
            document.getElementById('status-badge').className = 'payment-status payment-paid';
            document.getElementById('status-badge').innerHTML = '✅ Apostas confirmadas!';
            setTimeout(() => window.location.href = '/games/<%= payment.game_id %>?success=1', 1500);
          } else if (data.status === 'expired' || data.status === 'declined') {
            document.getElementById('status-badge').className = 'payment-status payment-expired';
            document.getElementById('status-badge').innerHTML = '⛔ Prazo encerrado — PIX não aceito';
          }
        });
    }

    setInterval(checkStatus, 4000);
    checkStatus();
  </script>
</body>
</html>
